<Window x:Class="NasaqVendor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:NasaqVendor.Views.Pages"
        xmlns:vm="clr-namespace:NasaqVendor.ViewModels"
        xmlns:common="clr-namespace:NasaqVendor.Views.Common"
        Style="{StaticResource BaseWindowStyle}"
        Title="أداة إصدار التراخيص — نَسَق"
        Width="1100" Height="720"
        MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CustomersViewModel}">
            <pages:CustomersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LicensesViewModel}">
            <pages:LicensesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:KeySettingsViewModel}">
            <pages:KeySettingsView />
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="14"
            Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#0E2A47" BlurRadius="32" ShadowDepth="0" Opacity="0.28" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Header (spans both columns) -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource NavySidebarBrush}"
                    CornerRadius="14,14,0,0"
                    Padding="22,14"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{StaticResource TealPrimaryBrush}"
                                VerticalAlignment="Center">
                            <TextBlock Text="ن"
                                       Foreground="White"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="أداة إصدار التراخيص — نَسَق"
                                       Foreground="White"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold" />
                            <TextBlock Text="إنشاء وتوقيع ملفات الترخيص (.naslic)"
                                       Foreground="#B8C7DA"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeSm}" />
                        </StackPanel>
                    </StackPanel>

                    <Button HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Width="34" Height="34"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            Cursor="Hand"
                            Click="CloseBtn_Click"
                            ToolTip="إغلاق">
                        <Path Data="{StaticResource IconX}"
                              Stroke="White"
                              StrokeThickness="1.8"
                              Fill="Transparent"
                              Width="16" Height="16"
                              Stretch="Uniform" />
                    </Button>
                </Grid>
            </Border>

            <!-- Sidebar -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource NavySidebarBrush}"
                    CornerRadius="0,0,0,14">
                <StackPanel Orientation="Vertical" Margin="0,16">

                    <Button Command="{Binding ShowCustomersCommand}"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Padding="0"
                            Margin="0,2,0,2">
                        <Grid>
                            <Border x:Name="CustomersActiveStrip"
                                    Width="3"
                                    Background="{StaticResource TealPrimaryBrush}"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=customers}" />
                            <StackPanel Orientation="Horizontal" Margin="22,12">
                                <Path Data="{StaticResource IconCustomers}"
                                      Stroke="White"
                                      StrokeThickness="1.6"
                                      Fill="Transparent"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center" />
                                <TextBlock Text="العملاء"
                                           Foreground="White"
                                           FontFamily="{StaticResource TajawalFont}"
                                           FontSize="{StaticResource FontSizeBase}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Command="{Binding ShowLicensesCommand}"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Padding="0"
                            Margin="0,2,0,2">
                        <Grid>
                            <Border Width="3"
                                    Background="{StaticResource TealPrimaryBrush}"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=licenses}" />
                            <StackPanel Orientation="Horizontal" Margin="22,12">
                                <Path Data="{StaticResource IconLicenses}"
                                      Stroke="White"
                                      StrokeThickness="1.6"
                                      Fill="Transparent"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center" />
                                <TextBlock Text="التراخيص"
                                           Foreground="White"
                                           FontFamily="{StaticResource TajawalFont}"
                                           FontSize="{StaticResource FontSizeBase}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Command="{Binding ShowKeySettingsCommand}"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Padding="0"
                            Margin="0,2,0,2">
                        <Grid>
                            <Border Width="3"
                                    Background="{StaticResource TealPrimaryBrush}"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding ActivePage, Converter={StaticResource ActivePageConverter}, ConverterParameter=keys}" />
                            <StackPanel Orientation="Horizontal" Margin="22,12">
                                <Path Data="{StaticResource IconKey}"
                                      Stroke="White"
                                      StrokeThickness="1.6"
                                      Fill="Transparent"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center" />
                                <TextBlock Text="إعدادات المفتاح"
                                           Foreground="White"
                                           FontFamily="{StaticResource TajawalFont}"
                                           FontSize="{StaticResource FontSizeBase}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Status bar at bottom -->
                    <StackPanel Orientation="Vertical"
                                VerticalAlignment="Bottom"
                                Margin="22,40,22,16">
                        <Border CornerRadius="8"
                                Padding="10,8"
                                Background="#163252">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconShield}"
                                      Stroke="#1FB5A8"
                                      StrokeThickness="1.6"
                                      Fill="Transparent"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="مفتاح غير محمَّل" />
                                            <Setter Property="Foreground" Value="#F59E0B" />
                                            <Setter Property="FontFamily" Value="{StaticResource TajawalFont}" />
                                            <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasKey}" Value="True">
                                                    <Setter Property="Text" Value="المفتاح جاهز" />
                                                    <Setter Property="Foreground" Value="#22C55E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Grid.Column="1">
                <ContentControl Content="{Binding CurrentPage}" />

                <!-- Toast layer on top, anchored bottom-left -->
                <common:ToastHost x:Name="ToastHostInstance" />
            </Grid>
        </Grid>
    </Border>
</Window>
