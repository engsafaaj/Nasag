<Window x:Class="NasaqVendor.Views.Dialogs.RevokeLicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource BaseWindowStyle}"
        Title="إبطال ترخيص"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="22,18,22,8" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="20"
                            Background="{StaticResource DangerSoftBrush}" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconRevoke}"
                              Stroke="{StaticResource DangerBrush}"
                              StrokeThickness="1.8"
                              Fill="Transparent"
                              Width="20" Height="20"
                              Stretch="Uniform" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="إبطال الترخيص" Style="{StaticResource SubheadTextStyle}" />
                        <TextBlock Text="{Binding LicenseLabel}" Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="22,8,22,16">
                <TextBlock Style="{StaticResource MutedTextStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10">
                    <Run Text="سيتم إبطال ترخيص العميل " />
                    <Run Text="{Binding CustomerName}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <Run Text=". لا يمكن التراجع بعد التأكيد." />
                </TextBlock>
                <TextBlock Text="سبب الإبطال (اختياري)" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Padding="22,8"
                            Margin="0,0,10,0" />
                    <Button Style="{StaticResource DangerButton}"
                            Content="تأكيد الإبطال"
                            Command="{Binding ConfirmCommand}"
                            IsDefault="True"
                            Padding="26,8" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
