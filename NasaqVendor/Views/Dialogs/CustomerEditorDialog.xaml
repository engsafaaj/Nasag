<Window x:Class="NasaqVendor.Views.Dialogs.CustomerEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource BaseWindowStyle}"
        Title="عميل"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="22,18,22,8" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="{Binding Title}" Style="{StaticResource SubheadTextStyle}" />
            </Border>

            <StackPanel Grid.Row="1" Margin="22,8,22,16">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="الرمز" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="الاسم" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="الهاتف" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="المدينة" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="البريد الإلكتروني" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="64"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>

                <Border Background="{StaticResource DangerSoftBrush}"
                        CornerRadius="6"
                        Padding="10,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="إلغاء"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Padding="22,8"
                            Margin="0,0,10,0" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="حفظ"
                            Command="{Binding SaveCommand}"
                            IsDefault="True"
                            Padding="26,8" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
