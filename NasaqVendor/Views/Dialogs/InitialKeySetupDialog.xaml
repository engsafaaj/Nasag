<Window x:Class="NasaqVendor.Views.Dialogs.InitialKeySetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource BaseWindowStyle}"
        Title="إعداد المفاتيح"
        Width="620"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="22,18,22,8" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="20"
                            Background="{StaticResource TealSoftBrush}" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconKey}"
                              Stroke="{StaticResource TealPressedBrush}"
                              StrokeThickness="1.8"
                              Fill="Transparent"
                              Width="20" Height="20"
                              Stretch="Uniform" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="إعداد مفاتيح الإصدار" Style="{StaticResource SubheadTextStyle}" />
                        <TextBlock Text="إنشاء أو استيراد المفتاح المُستخدم لتوقيع التراخيص."
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="22,8,22,16">
                <Border Background="{StaticResource InfoSoftBrush}"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,16">
                    <TextBlock Text="هذا الإعداد لمرة واحدة. المفتاح الخاص سيُحفظ مُشفَّراً عبر DPAPI (نطاق المستخدم الحالي). لن يُعرض المفتاح الخاص في أي مكان."
                               Foreground="{StaticResource InfoBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="توليد زوج مفاتيح جديد" Style="{StaticResource SubheadTextStyle}" />
                            <TextBlock Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,12"
                                       Text="ينشئ منحنى ECDSA-P256 جديد ويطلب منك حفظ المفتاح العام لتضمينه في تطبيق Nasag." />
                            <Button Style="{StaticResource PrimaryButton}"
                                    Content="توليد المفاتيح"
                                    Command="{Binding GenerateCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="استيراد مفتاح خاص موجود" Style="{StaticResource SubheadTextStyle}" />
                            <TextBlock Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,12"
                                       Text="يقبل ملف raw bytes الناتج عن ExportECPrivateKey لمنحنى P-256." />
                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="اختر ملفاً…"
                                    Command="{Binding ImportCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{StaticResource SuccessSoftBrush}"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,8,0,0"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               TextWrapping="Wrap" />
                </Border>
                <Border Background="{StaticResource DangerSoftBrush}"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,8,0,0"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="تخطٍّ"
                            Command="{Binding SkipCommand}"
                            IsCancel="True"
                            Padding="22,8"
                            Margin="0,0,10,0" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="تم"
                            Command="{Binding DoneCommand}"
                            IsDefault="True"
                            Padding="26,8" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
