<Window x:Class="NasaqVendor.Views.Dialogs.AuditLogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource BaseWindowStyle}"
        Title="سجل التدقيق"
        Width="720" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="22,18,22,8" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock Text="سجل التدقيق" Style="{StaticResource SubheadTextStyle}" />
                    <TextBlock Text="{Binding HeaderText}" Style="{StaticResource MutedTextStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Margin="22,8,22,16" CornerRadius="10" ClipToBounds="True">
                <DataGrid ItemsSource="{Binding Items}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الإجراء" Binding="{Binding Action}" Width="140" />
                        <DataGridTextColumn Header="عند (UTC)" Binding="{Binding AtUtc, Converter={StaticResource DateToString}}" Width="160" />
                        <DataGridTextColumn Header="المستخدم" Binding="{Binding Operator}" Width="140" />
                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <Button HorizontalAlignment="Left"
                        Style="{StaticResource PrimaryButton}"
                        Content="إغلاق"
                        Command="{Binding CloseCommand}"
                        IsDefault="True"
                        Padding="26,8" />
            </Border>
        </Grid>
    </Border>
</Window>
