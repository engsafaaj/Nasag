<Window x:Class="NasaqVendor.Views.Common.VendorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource BaseWindowStyle}"
        Title="نَسَق — أداة الإصدار"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="22,18,22,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="IconBubble"
                            Width="44" Height="44"
                            CornerRadius="22"
                            Background="{StaticResource TealSoftBrush}"
                            VerticalAlignment="Center">
                        <Path x:Name="IconPath"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="22" Height="22"
                              Data="M12 8 H12.01 M11 12 H12 V17 H13"
                              Stroke="{StaticResource TealPressedBrush}" />
                    </Border>
                    <TextBlock x:Name="TitleText"
                               Text="عنوان"
                               FontFamily="{StaticResource TajawalFont}"
                               FontSize="{StaticResource FontSizeLg}"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Padding="22,4,22,18">
                <TextBlock x:Name="MessageText"
                           Text="رسالة"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           TextAlignment="Right" />
            </Border>

            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="CancelBtn"
                            Style="{StaticResource SecondaryButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Click="OnCancelClick"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button x:Name="ConfirmBtn"
                            Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Click="OnConfirmClick"
                            Content="تأكيد"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
