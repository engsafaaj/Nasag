<UserControl x:Class="NasaqVendor.Views.Pages.LicensesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="التراخيص" Style="{StaticResource SectionTitle}" />
            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                <TextBlock Style="{StaticResource SectionSubtitle}" Margin="0,0,0,0">
                    <Run Text="إجمالي: " />
                    <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource TealPressedBrush}" />
                </TextBlock>
                <TextBlock Style="{StaticResource SectionSubtitle}" Margin="14,0,0,0">
                    <Run Text="نشط: " />
                    <Run Text="{Binding ActiveCount, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                </TextBlock>
                <TextBlock Style="{StaticResource SectionSubtitle}" Margin="14,0,0,0">
                    <Run Text="مُبطَل: " />
                    <Run Text="{Binding RevokedCount, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                     MaxWidth="380"
                     HorizontalAlignment="Right"
                     Tag="ابحث باسم العميل…" />

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StatusFilters}"
                      SelectedItem="{Binding StatusFilter}"
                      Margin="10,0,0,0" />

            <Button Grid.Column="2"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource IconButton}"
                    ToolTip="تحديث"
                    Margin="8,0,0,0">
                <Path Data="{StaticResource IconRefresh}"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="1.6"
                      Fill="Transparent"
                      Width="18" Height="18"
                      Stretch="Uniform" />
            </Button>

            <Button Grid.Column="3"
                    Command="{Binding IssueCommand}"
                    Style="{StaticResource BubbleButton}"
                    IsEnabled="{Binding CanIssue}"
                    Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconCertificate}"
                          Stroke="White"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Width="16" Height="16"
                          Stretch="Uniform"
                          VerticalAlignment="Center" />
                    <TextBlock Text="إصدار ترخيص جديد" Margin="8,0,0,0" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2" CornerRadius="10" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Items}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="60" />
                    <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="*" />
                    <DataGridTextColumn Header="الإصدار" Binding="{Binding Edition, Converter={StaticResource EditionToArabic}}" Width="110" />
                    <DataGridTextColumn Header="أُصدر في" Binding="{Binding IssuedAtUtc, Converter={StaticResource DateToString}}" Width="140" />
                    <DataGridTextColumn Header="ينتهي في" Binding="{Binding ExpiresAtUtc, Converter={StaticResource DateOnlyToString}}" Width="120" />
                    <DataGridTemplateColumn Header="الملف" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LicenseFilePath, Converter={StaticResource TruncatePath}}"
                                           ToolTip="{Binding LicenseFilePath}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="{StaticResource FontSizeSm}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="الحالة" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="999" Padding="10,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Revoked}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="{StaticResource FontSizeSm}" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="نشط" />
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Revoked}" Value="True">
                                                        <Setter Property="Text" Value="مُبطَل" />
                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="إجراءات" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource RowActionButton}"
                                            Command="{Binding DataContext.ViewAuditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="سجل التدقيق">
                                        <Path Data="{StaticResource IconAuditLog}"
                                              Stroke="{StaticResource TealPressedBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Width="16" Height="16"
                                              Stretch="Uniform" />
                                    </Button>
                                    <Button Style="{StaticResource RowActionButton}"
                                            Command="{Binding DataContext.ReExportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="إعادة تصدير"
                                            Margin="4,0,0,0">
                                        <Path Data="{StaticResource IconExport}"
                                              Stroke="{StaticResource NavyDeepBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Width="16" Height="16"
                                              Stretch="Uniform" />
                                    </Button>
                                    <Button Style="{StaticResource RowActionButton}"
                                            Command="{Binding DataContext.RevokeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="إبطال"
                                            Margin="4,0,0,0">
                                        <Path Data="{StaticResource IconRevoke}"
                                              Stroke="{StaticResource DangerBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Width="16" Height="16"
                                              Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
