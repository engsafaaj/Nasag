<UserControl x:Class="NasaqVendor.Views.Pages.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="العملاء" Style="{StaticResource SectionTitle}" />
            <TextBlock Style="{StaticResource SectionSubtitle}">
                <Run Text="إجمالي: " />
                <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource TealPressedBrush}" />
            </TextBlock>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                     MaxWidth="380"
                     HorizontalAlignment="Right"
                     Tag="ابحث عن عميل…" />

            <Button Grid.Column="1"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource IconButton}"
                    ToolTip="تحديث"
                    Margin="8,0,0,0">
                <Path Data="{StaticResource IconRefresh}"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="1.6"
                      Fill="Transparent"
                      Width="18" Height="18"
                      Stretch="Uniform" />
            </Button>

            <Button Grid.Column="2"
                    Command="{Binding AddCommand}"
                    Style="{StaticResource BubbleButton}"
                    Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconAdd}"
                          Stroke="White"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Width="16" Height="16"
                          Stretch="Uniform"
                          VerticalAlignment="Center" />
                    <TextBlock Text="إضافة عميل" Margin="8,0,0,0" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2" CornerRadius="10" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Items}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="الرمز" Binding="{Binding Code}" Width="120" />
                    <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="140" />
                    <DataGridTextColumn Header="المدينة" Binding="{Binding City}" Width="120" />
                    <DataGridTextColumn Header="البريد" Binding="{Binding Email}" Width="180" />
                    <DataGridTextColumn Header="أُنشئ في" Binding="{Binding CreatedAtUtc, Converter={StaticResource DateOnlyToString}}" Width="120" />
                    <DataGridTemplateColumn Header="إجراءات" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource RowActionButton}"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="تعديل">
                                        <Path Data="{StaticResource IconEdit}"
                                              Stroke="{StaticResource TealPressedBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Width="16" Height="16"
                                              Stretch="Uniform" />
                                    </Button>
                                    <Button Style="{StaticResource RowActionButton}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="حذف"
                                            Margin="4,0,0,0">
                                        <Path Data="{StaticResource IconDelete}"
                                              Stroke="{StaticResource DangerBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Width="16" Height="16"
                                              Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
