<Window x:Class="NasaqPackager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:NasaqPackager.Helpers"
        Style="{StaticResource BaseWindowStyle}"
        Title="أداة تحزيم نَسَق"
        Width="980"
        Height="640"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InverseBoolConverter x:Key="InverseBool" />
    </Window.Resources>

    <Border CornerRadius="14"
            Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="14">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Row 0 — Header -->
            <Border Grid.Row="0"
                    Padding="22,16,18,16"
                    Background="{StaticResource CardSurfaceBrush}"
                    CornerRadius="14,14,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo bubble + title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="22"
                                Background="{StaticResource TealPrimaryBrush}"
                                VerticalAlignment="Center">
                            <TextBlock Text="ن"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="أداة تحزيم نَسَق"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="بناء وإصدار النسخ عبر Velopack"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinBtn"
                                Style="{StaticResource IconButton}"
                                Click="OnMinimizeClick"
                                ToolTip="تصغير">
                            <Path Data="M5 12 H19"
                                  Stroke="{StaticResource TextSecondaryBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  Width="16" Height="16" />
                        </Button>
                        <Button x:Name="CloseBtn"
                                Style="{StaticResource IconButton}"
                                Margin="4,0,0,0"
                                Click="OnCloseClick"
                                ToolTip="إغلاق">
                            <Path Data="M6 6 L18 18 M18 6 L6 18"
                                  Stroke="{StaticResource DangerBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  Width="14" Height="14" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Row 1 — Info bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="22,12,18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Version chip -->
                        <Border Background="{StaticResource TealSoftBrush}"
                                CornerRadius="999"
                                Padding="12,5"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="النسخة الحالية:"
                                           FontFamily="{StaticResource TajawalFont}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           Foreground="{StaticResource TealPressedBrush}" />
                                <TextBlock Text="{Binding CurrentVersion}"
                                           FontFamily="{StaticResource TajawalFont}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TealPressedBrush}"
                                           Margin="6,0,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Project path chip -->
                        <Border Background="{StaticResource BackgroundBrush}"
                                CornerRadius="999"
                                Padding="12,5"
                                Margin="0,0,8,0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="المشروع:"
                                           Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Text="{Binding ProjectPath}"
                                           FontFamily="{StaticResource TajawalFont}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           FlowDirection="LeftToRight"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="360"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="6,0,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Releases path chip -->
                        <Border Background="{StaticResource BackgroundBrush}"
                                CornerRadius="999"
                                Padding="12,5"
                                Margin="0,0,8,0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="الإصدارات:"
                                           Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Text="{Binding ReleasesPath}"
                                           FontFamily="{StaticResource TajawalFont}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           FlowDirection="LeftToRight"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="280"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="6,0,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="الإعدادات">
                        <Path Data="M12 8 A4 4 0 1 1 12 16 A4 4 0 1 1 12 8 Z M19 12 A7 7 0 1 0 12 19 M5 12 A7 7 0 1 0 12 5"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1.6"
                              Stretch="Uniform"
                              Width="18" Height="18"
                              Fill="Transparent" />
                    </Button>
                </Grid>
            </Border>

            <!-- Row 2 — Body -->
            <Grid Grid.Row="2" Margin="22,18,22,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Action column -->
                <StackPanel Grid.Column="0" Width="240" VerticalAlignment="Top">
                    <Button Style="{StaticResource BubbleXxl}"
                            Command="{Binding BumpVersionCommand}"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <!-- Up-arrow icon -->
                            <Path Data="M12 4 L12 20 M5 11 L12 4 L19 11"
                                  Stroke="White"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="28" Height="28"
                                  HorizontalAlignment="Center" />
                            <TextBlock Text="زيادة رقم النسخة"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeMd}"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BubbleXxl}"
                            Command="{Binding PackageCommand}"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <!-- Package / box icon -->
                            <Path Data="M3 7 L12 3 L21 7 L21 17 L12 21 L3 17 Z M3 7 L12 11 L21 7 M12 11 L12 21"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="32" Height="32"
                                  HorizontalAlignment="Center" />
                            <TextBlock Text="تحزيم وإصدار"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeMd}"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BubbleXxl}"
                            Command="{Binding OpenReleasesCommand}">
                        <StackPanel>
                            <!-- Folder icon -->
                            <Path Data="M3 7 L3 19 L21 19 L21 9 L11 9 L9 7 Z"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="32" Height="32"
                                  HorizontalAlignment="Center" />
                            <TextBlock Text="فتح مجلد الإصدارات"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeMd}"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Log card -->
                <Border Grid.Column="1"
                        Margin="18,0,0,0"
                        Background="{StaticResource CardSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Log toolbar -->
                        <Border Grid.Row="0"
                                Padding="12,8"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="9" Height="9" Fill="{StaticResource TealPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="سجل التشغيل"
                                               FontFamily="{StaticResource TajawalFont}"
                                               FontSize="{StaticResource FontSizeBase}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="(قيد التنفيذ…)"
                                               Style="{StaticResource CaptionTextStyle}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"
                                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource GhostButton}"
                                            Command="{Binding CopyLogCommand}"
                                            Content="نسخ"
                                            Padding="12,6" />
                                    <Button Style="{StaticResource GhostButton}"
                                            Command="{Binding ClearLogCommand}"
                                            Content="مسح"
                                            Padding="12,6"
                                            Margin="6,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Terminal text -->
                        <Border Grid.Row="1"
                                CornerRadius="0,0,14,14"
                                Background="#0E2A47"
                                ClipToBounds="True">
                            <TextBox x:Name="LogBox"
                                     Style="{StaticResource TerminalTextBox}"
                                     Text="{Binding LogText, Mode=OneWay}"
                                     TextChanged="LogBox_TextChanged" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
