<Window x:Class="NasaqPackager.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource BaseWindowStyle}"
        Title="إعدادات أداة التحزيم"
        Width="640"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Padding="22,18,22,12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40"
                            CornerRadius="20"
                            Background="{StaticResource TealSoftBrush}"
                            VerticalAlignment="Center">
                        <Path Data="M12 8 A4 4 0 1 1 12 16 A4 4 0 1 1 12 8 Z M19 12 A7 7 0 1 0 12 19 M5 12 A7 7 0 1 0 12 5"
                              Stroke="{StaticResource TealPressedBrush}"
                              StrokeThickness="1.8"
                              Stretch="Uniform"
                              Width="20" Height="20"
                              Fill="Transparent" />
                    </Border>
                    <TextBlock Text="إعدادات أداة التحزيم"
                               FontFamily="{StaticResource TajawalFont}"
                               FontSize="{StaticResource FontSizeLg}"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="22,4,22,16">
                <StackPanel>
                    <!-- Project path -->
                    <TextBlock Text="مسار مشروع Nasag (csproj)"
                               Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ProjectPath, UpdateSourceTrigger=PropertyChanged}"
                                 FlowDirection="LeftToRight" />
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseProjectCommand}"
                                Content="استعراض…"
                                Margin="8,0,0,0"
                                Padding="14,8" />
                    </Grid>

                    <!-- Releases path -->
                    <TextBlock Text="مسار مجلد الإصدارات"
                               Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ReleasesPath, UpdateSourceTrigger=PropertyChanged}"
                                 FlowDirection="LeftToRight" />
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseReleasesCommand}"
                                Content="استعراض…"
                                Margin="8,0,0,0"
                                Padding="14,8" />
                    </Grid>

                    <!-- Icon path -->
                    <TextBlock Text="مسار الأيقونة (اختياري)"
                               Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding IconPath, UpdateSourceTrigger=PropertyChanged}"
                                 FlowDirection="LeftToRight" />
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseIconCommand}"
                                Content="استعراض…"
                                Margin="8,0,0,0"
                                Padding="14,8" />
                    </Grid>

                    <!-- Channel + RID side-by-side -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="اسم القناة" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Channel, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="RuntimeIdentifier" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding Rids}"
                                      SelectedItem="{Binding RuntimeIdentifier}" />
                        </StackPanel>
                    </Grid>

                    <!-- PackId + PackTitle -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="معرّف الحزمة (PackId)" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding PackId, UpdateSourceTrigger=PropertyChanged}"
                                     FlowDirection="LeftToRight" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="عنوان الحزمة (PackTitle)" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding PackTitle, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <!-- Toggles -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <CheckBox IsChecked="{Binding SelfContained}"
                                  Content=" self-contained"
                                  FontFamily="{StaticResource TajawalFont}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,18,0" />
                        <CheckBox IsChecked="{Binding RunObfuscar}"
                                  Content=" تشغيل Obfuscar"
                                  FontFamily="{StaticResource TajawalFont}"
                                  Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}"
                            Content="إلغاء"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}"
                            Content="حفظ"
                            Padding="26,8"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
