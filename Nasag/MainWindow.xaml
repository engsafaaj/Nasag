<Window x:Class="Nasag.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nasag"
        xmlns:vm="clr-namespace:Nasag.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="نَسَق لإدارة المدارس"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Center hero card — proves: Tajawal font, RTL, Navy + Teal palette, soft shadows, rounded corners -->
        <Border Grid.Row="0"
                Background="{StaticResource CardSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLg}"
                MaxWidth="560"
                Padding="48"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#1B3A57" BlurRadius="24" ShadowDepth="0" Opacity="0.08" />
            </Border.Effect>

            <StackPanel HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/Images/Logo.png"
                       Width="120" Height="120"
                       Margin="0,0,0,16" />

                <TextBlock Text="{Binding AppName}"
                           Style="{StaticResource HeadingTextStyle}"
                           HorizontalAlignment="Center" />

                <TextBlock Text="{Binding Tagline}"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,24" />

                <Border Background="{StaticResource TealSoftBrush}"
                        CornerRadius="{StaticResource RadiusSm}"
                        Padding="14,8"
                        HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center">
                        <Run Text="الإصدار " Foreground="{StaticResource TealPressedBrush}" />
                        <Run Text="{Binding Version}" FontWeight="Bold" Foreground="{StaticResource TealPressedBrush}" />
                    </TextBlock>
                </Border>

                <TextBlock Text="المرحلة 1: تم تحميل الأساس بنجاح ✓"
                           Style="{StaticResource CaptionTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,24,0,0" />
            </StackPanel>
        </Border>

        <!-- Footer: color swatches verify the palette resolved -->
        <Border Grid.Row="1"
                Background="{StaticResource CardSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <Border Background="{StaticResource NavySidebarBrush}" Width="20" Height="20" CornerRadius="4" />
                    <TextBlock Text="Navy" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <Border Background="{StaticResource TealPrimaryBrush}" Width="20" Height="20" CornerRadius="4" />
                    <TextBlock Text="Teal" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <Border Background="{StaticResource SuccessBrush}" Width="20" Height="20" CornerRadius="4" />
                    <TextBlock Text="Success" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <Border Background="{StaticResource WarningBrush}" Width="20" Height="20" CornerRadius="4" />
                    <TextBlock Text="Warning" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <Border Background="{StaticResource DangerBrush}" Width="20" Height="20" CornerRadius="4" />
                    <TextBlock Text="Danger" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <Border Background="{StaticResource InfoBrush}" Width="20" Height="20" CornerRadius="4" />
                    <TextBlock Text="Info" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
