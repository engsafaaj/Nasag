<Window x:Class="Nasag.Views.Licensing.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:helpers="clr-namespace:Nasag.Helpers"
        xmlns:vm="clr-namespace:Nasag.ViewModels.Licensing"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ActivationViewModel}"
        Title="تفعيل البرنامج"
        Width="720"
        Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolConverter x:Key="InverseBool" />
    </Window.Resources>

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Padding="22,18,22,8"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="22"
                                Background="{StaticResource TealSoftBrush}"
                                VerticalAlignment="Center">
                            <Path Data="{StaticResource IconKey}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="22" Height="22" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="تفعيل البرنامج"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding StepIndicatorText}"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Command="{Binding CancelCommand}"
                            ToolTip="إغلاق"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- Stepper dots (4 steps) -->
            <Border Grid.Row="1" Padding="22,0,22,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource BorderStrongBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep0Active}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource TealPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Border Width="22" Height="2" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource BorderStrongBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource TealPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <Ellipse Width="10" Height="10" Margin="0,0,4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource BorderStrongBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1Active}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource TealPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Border Width="22" Height="2" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource BorderStrongBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource TealPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <Ellipse Width="10" Height="10" Margin="0,0,4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource BorderStrongBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2Active}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource TealPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Border Width="22" Height="2" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource BorderStrongBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource TealPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <Ellipse Width="10" Height="10">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource BorderStrongBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3Active}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource TealPrimaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="22,6,22,18">
                <Grid>
                    <!-- ════ Step 0 — Welcome ════ -->
                    <StackPanel Visibility="{Binding IsStep0, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="مرحباً بك"
                                   FontFamily="{StaticResource TajawalFont}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,10" />
                        <TextBlock Style="{StaticResource BodyTextStyle}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="24"
                                   Margin="0,0,0,18"
                                   Text="نَسَق يحتاج إلى ترخيص لربطه بهذا الجهاز. اختر إن كنت تملك ملف ترخيص جاهز أو تحتاج إلى استخراج بصمة الجهاز لإرسالها إلى المورِّد." />

                        <RadioButton GroupName="ActIntent"
                                     IsChecked="{Binding HasLicenseFile, Mode=TwoWay}"
                                     Cursor="Hand"
                                     Margin="0,0,0,12">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Root"
                                            CornerRadius="12"
                                            Background="{StaticResource BackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="2"
                                            Padding="18,16">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="44" Height="44" CornerRadius="22"
                                                    Background="{StaticResource TealSoftBrush}"
                                                    VerticalAlignment="Top">
                                                <Path Data="{StaticResource IconCertificate}"
                                                      Stroke="{StaticResource TealPressedBrush}"
                                                      StrokeThickness="2"
                                                      Fill="Transparent"
                                                      Stretch="Uniform"
                                                      Width="22" Height="22" />
                                            </Border>
                                            <StackPanel Margin="14,0,0,0">
                                                <TextBlock Text="أملك ملف ترخيص"
                                                           FontWeight="Bold"
                                                           Style="{StaticResource SubheadTextStyle}" />
                                                <TextBlock Style="{StaticResource MutedTextStyle}"
                                                           FontSize="{StaticResource FontSizeSm}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           Text="حصلت على ملف .naslic من المورِّد وستحمّله الآن." />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource TealPrimaryBrush}" />
                                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TealSoftBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>

                        <RadioButton GroupName="ActIntent"
                                     IsChecked="{Binding NeedsNewLicense, Mode=TwoWay}"
                                     Cursor="Hand">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Root"
                                            CornerRadius="12"
                                            Background="{StaticResource BackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="2"
                                            Padding="18,16">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="44" Height="44" CornerRadius="22"
                                                    Background="{StaticResource InfoSoftBrush}"
                                                    VerticalAlignment="Top">
                                                <Path Data="{StaticResource IconCopy}"
                                                      Stroke="{StaticResource InfoBrush}"
                                                      StrokeThickness="2"
                                                      Fill="Transparent"
                                                      Stretch="Uniform"
                                                      Width="22" Height="22" />
                                            </Border>
                                            <StackPanel Margin="14,0,0,0">
                                                <TextBlock Text="أحتاج ترخيصاً جديداً"
                                                           FontWeight="Bold"
                                                           Style="{StaticResource SubheadTextStyle}" />
                                                <TextBlock Style="{StaticResource MutedTextStyle}"
                                                           FontSize="{StaticResource FontSizeSm}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           Text="ابدأ بنسخ بصمة الجهاز لإرسالها إلى المورِّد." />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource TealPrimaryBrush}" />
                                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TealSoftBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>

                    <!-- ════ Step 1 — Machine fingerprint ════ -->
                    <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="بصمة الجهاز"
                                   FontFamily="{StaticResource TajawalFont}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,4" />
                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                   Text="هذه التجزئات الخمس تربط الترخيص بهذا الجهاز. انسخها وأرسلها إلى المورِّد."
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="CPU" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding CpuHash, Mode=OneWay}" IsReadOnly="True" Padding="10,6" Margin="0,0,0,8" FontFamily="Consolas" />

                        <TextBlock Text="Board" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding BoardHash, Mode=OneWay}" IsReadOnly="True" Padding="10,6" Margin="0,0,0,8" FontFamily="Consolas" />

                        <TextBlock Text="BIOS" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding BiosHash, Mode=OneWay}" IsReadOnly="True" Padding="10,6" Margin="0,0,0,8" FontFamily="Consolas" />

                        <TextBlock Text="Machine" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding MachineHash, Mode=OneWay}" IsReadOnly="True" Padding="10,6" Margin="0,0,0,8" FontFamily="Consolas" />

                        <TextBlock Text="MAC" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding MacHash, Mode=OneWay}" IsReadOnly="True" Padding="10,6" Margin="0,0,0,12" FontFamily="Consolas" />

                        <TextBlock Text="كتلة موحَّدة جاهزة للنسخ" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding FingerprintBlock, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="120"
                                 FontFamily="Consolas"
                                 Padding="10,6"
                                 Margin="0,0,0,10" />

                        <TextBlock Text="اسم المدرسة (اختياري — يُساعد المورِّد على التعرف عليك)" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding SchoolName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,6"
                                 Margin="0,0,0,10" />

                        <Button Style="{StaticResource BubbleButton}"
                                Command="{Binding CopyFingerprintCommand}"
                                HorizontalAlignment="Right"
                                Padding="16,8">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <Path Data="{StaticResource IconCopy}"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Width="14" Height="14"
                                      VerticalAlignment="Center" />
                                <TextBlock Text="نسخ كل البيانات"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- ════ Step 2 — Upload / paste license ════ -->
                    <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="تحميل الترخيص"
                                   FontFamily="{StaticResource TajawalFont}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,4" />
                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                   Text="اختر ملف .naslic أو الصق محتواه ثم اضغط «التحقق»."
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <Button Command="{Binding PickLicenseFileCommand}"
                                Cursor="Hand"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Root"
                                            CornerRadius="12"
                                            Background="{StaticResource BackgroundBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}"
                                            BorderThickness="2"
                                            Padding="22,20"
                                            SnapsToDevicePixels="True">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Width="48" Height="48" CornerRadius="24"
                                                    Background="{StaticResource TealSoftBrush}"
                                                    HorizontalAlignment="Center">
                                                <Path Data="{StaticResource IconImport}"
                                                      Stroke="{StaticResource TealPressedBrush}"
                                                      StrokeThickness="2"
                                                      Fill="Transparent"
                                                      Stretch="Uniform"
                                                      Width="22" Height="22" />
                                            </Border>
                                            <TextBlock Style="{StaticResource BodyTextStyle}"
                                                       FontWeight="Medium"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,10,0,2"
                                                       Text="اضغط لاختيار ملف ترخيص (.naslic)" />
                                            <TextBlock Style="{StaticResource CaptionTextStyle}"
                                                       HorizontalAlignment="Center"
                                                       Text="{Binding LicenseFilePath}" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource TealPrimaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Text="أو الصق محتوى الترخيص" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding PastedLicenseJson, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="120"
                                 FontFamily="Consolas"
                                 Padding="10,6"
                                 Margin="0,0,0,10" />

                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding VerifyCommand}"
                                IsEnabled="{Binding IsVerifying, Converter={StaticResource InverseBool}}"
                                Padding="22,10"
                                HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                <Path Data="{StaticResource IconCheck}"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Width="14" Height="14"
                                      VerticalAlignment="Center" />
                                <TextBlock Text="التحقق"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="Medium" />
                            </StackPanel>
                        </Button>

                        <!-- Error banner -->
                        <Border Background="{StaticResource DangerSoftBrush}"
                                BorderBrush="{StaticResource DangerBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,10"
                                Margin="0,10,0,0"
                                Visibility="{Binding VerificationError, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding VerificationError}"
                                       Foreground="{StaticResource DangerBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <!-- ════ Step 3 — Done ════ -->
                    <StackPanel Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center">
                        <Border Width="72" Height="72"
                                CornerRadius="36"
                                Background="{StaticResource SuccessSoftBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,16">
                            <Path Data="{StaticResource IconCheckCircle}"
                                  Stroke="{StaticResource SuccessBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="40" Height="40" />
                        </Border>
                        <TextBlock Text="تم تفعيل البرنامج بنجاح"
                                   FontFamily="{StaticResource TajawalFont}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16" />

                        <Border Style="{StaticResource CardBorder}" Padding="16,14" MaxWidth="560" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="الزبون" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding VerifiedCustomerName}"
                                           Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8" />

                                <TextBlock Text="الإصدار" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding VerifiedEdition}"
                                           Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8" />

                                <TextBlock Text="المزايا" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="{Binding VerifiedFeatures}"
                                           Style="{StaticResource BodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="تاريخ الإصدار" Style="{StaticResource FieldLabel}" />
                                        <TextBlock Text="{Binding VerifiedIssuedAt}"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="تاريخ الانتهاء" Style="{StaticResource FieldLabel}" />
                                        <TextBlock Text="{Binding VerifiedExpiresAt}"
                                                   Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <Grid FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding CancelCommand}"
                            Padding="18,8"
                            Content="إلغاء" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                FlowDirection="LeftToRight">
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding PrevStepCommand}"
                                IsEnabled="{Binding IsFirstStep, Converter={StaticResource InverseBool}}"
                                Padding="20,8"
                                Margin="0,0,10,0"
                                Content="السابق" />
                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding NextStepCommand}"
                                IsEnabled="{Binding CanGoNext}"
                                Padding="22,8"
                                Content="{Binding NextButtonText}"
                                IsDefault="True" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
