<Window x:Class="Nasag.Views.Licensing.UpdateSourceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="مصدر التحديثات"
        Width="560" Height="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="{StaticResource TajawalFont}">
    <Border Background="{StaticResource CardBackgroundBrush}"
            CornerRadius="14"
            BorderBrush="{StaticResource BorderStrongBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="28" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown" Margin="22,18,22,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                        Background="{StaticResource TealSoftBrush}">
                    <Path Data="{StaticResource IconDownload}" Stretch="Uniform"
                          Width="20" Height="20" Stroke="{StaticResource TealPrimaryBrush}"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Fill="Transparent" />
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="مصدر التحديثات" FontWeight="Bold" FontSize="18"
                               Foreground="{StaticResource NavyDeepBrush}" />
                    <TextBlock Text="مجلد محلي/شبكي أو رابط HTTP أو مستودع GitHub"
                               Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="2" Width="32" Height="32" Background="Transparent" BorderThickness="0"
                        Click="Close_Click" ToolTip="إغلاق">
                    <TextBlock Text="✕" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>
            </Grid>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="22,8,22,8">
                <TextBlock Text="المصدر الحالي:" Style="{StaticResource FieldLabel}" />
                <TextBox x:Name="SourceField" Margin="0,4,0,4"
                         FontFamily="Consolas, {StaticResource TajawalFont}"
                         FlowDirection="LeftToRight"
                         Padding="10,8" FontSize="13" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap">
                    أمثلة مقبولة:
                </TextBlock>
                <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8"
                        Padding="10" Margin="0,6,0,0">
                    <StackPanel FlowDirection="LeftToRight">
                        <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="C:\Releases\Nasaq" Margin="0,0,0,2" />
                        <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="\\fileserver\share\NasaqReleases" Margin="0,0,0,2" />
                        <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="https://updates.example.com/nasaq" Margin="0,0,0,2" />
                        <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="https://github.com/owner/nasaq-releases" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Footer -->
            <Grid Grid.Row="2" Margin="22,8,22,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="تصفّح مجلد..." Style="{StaticResource SecondaryButton}"
                        Click="Browse_Click" />
                <Button Grid.Column="2" Content="إلغاء" Style="{StaticResource GhostButton}"
                        Click="Cancel_Click" Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="حفظ" Style="{StaticResource PrimaryButton}"
                        Click="Save_Click" IsDefault="True" />
            </Grid>
        </Grid>
    </Border>
</Window>
