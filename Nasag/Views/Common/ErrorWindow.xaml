<Window x:Class="Nasag.Views.Common.ErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="نَسَق — تقرير خطأ"
        Height="540" Width="720"
        MinHeight="420" MinWidth="540"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource TajawalFont}"
        FontSize="{StaticResource FontSizeBase}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Background="{StaticResource BackgroundBrush}"
        UseLayoutRounding="True"
        ShowInTaskbar="False">
    <Border Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource DangerBrush}" Padding="22,16">
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36"
                            CornerRadius="18"
                            Background="#33000000"
                            VerticalAlignment="Center">
                        <Path Data="M12 9 V13 M12 17 H12.01 M2 20 L12 4 L22 20 Z"
                              Stroke="White"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="20" Height="20" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   Foreground="White"
                                   FontSize="{StaticResource FontSizeLg}"
                                   FontWeight="Bold" />
                        <TextBlock Text="يمكنك نسخ كامل التفاصيل ومشاركتها مع الدعم الفني"
                                   Foreground="#E8E8E8"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- User-friendly message -->
            <Border Grid.Row="1"
                    Background="{StaticResource DangerSoftBrush}"
                    Padding="22,16"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <TextBlock x:Name="UserMessageText"
                           Foreground="{StaticResource DangerBrush}"
                           FontWeight="Medium"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Technical details -->
            <Border Grid.Row="2" Padding="22,16,22,0">
                <Border Background="{StaticResource CardSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="14,8">
                            <TextBlock Text="التفاصيل الفنية"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontWeight="Medium" />
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Padding="14,8">
                            <TextBox x:Name="DetailsBox"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontFamily="Consolas, Cascadia Mono, Courier New"
                                     FontSize="12"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     FlowDirection="LeftToRight" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Border>

            <!-- Action bar -->
            <Border Grid.Row="3" Padding="22,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource SecondaryButton}"
                            Click="OnCopyClick"
                            Padding="18,8">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M9 4 H17 V18 H9 Z M5 8 V20 H13"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.6"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center" />
                            <TextBlock x:Name="CopyButtonText"
                                       Text="نسخ كامل التفاصيل"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnCloseClick"
                            Padding="28,8"
                            IsDefault="True">
                        <TextBlock Text="إغلاق" />
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
