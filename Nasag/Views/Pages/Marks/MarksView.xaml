<UserControl x:Class="Nasag.Views.Pages.Marks.MarksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Marks"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MarksViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <Style x:Key="CompactMetricCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="MinHeight" Value="78" />
        </Style>

        <Style x:Key="MarkStatusText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAbsent}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPassed}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ReloadCommand}"
                    VerticalAlignment="Center"
                    Padding="14,8"
                    ToolTip="تحديث البيانات (F5)">
                <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                    <Path Data="{StaticResource IconRefresh}"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="14" Height="14"
                          VerticalAlignment="Center" />
                    <TextBlock Text="تحديث"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="2"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleAr}"
                           Style="{StaticResource SectionTitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding SubtitleAr}"
                           Style="{StaticResource SectionSubtitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="14,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="140" />
                    <ColumnDefinition Width="Auto" MinWidth="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="الصف"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding Grades}"
                                                 SelectedItem="{Binding SelectedGrade, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الصف"
                                                 ToolTip="{Binding SelectedGrade.NameAr}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="الشعبة"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding AvailableSections}"
                                                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الشعبة"
                                                 ToolTip="{Binding SelectedSection.NameAr}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                    <TextBlock Text="المادة"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding AvailableSubjects}"
                                                 SelectedItem="{Binding SelectedSubject, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="المادة"
                                                 ToolTip="{Binding SelectedSubject.NameAr}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="8,0,0,0">
                    <TextBlock Text="الامتحان"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding Exams}"
                                                 SelectedItem="{Binding SelectedExam, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الامتحان"
                                                 ToolTip="{Binding SelectedExam.NameAr}" />
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Margin="8,0,0,0">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearAllCommand}"
                            Padding="14,8"
                            ToolTip="مسح جميع الدرجات المُدخَلة">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <Path Data="{StaticResource IconFilterClear}"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.7"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="مسح الكل"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Grid.Column="5"
                        Style="{StaticResource BubbleButton}"
                        Command="{Binding SaveCommand}"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0"
                        Padding="16,8"
                        ToolTip="حفظ الدرجات (Ctrl+S)">
                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                        <Path Data="{StaticResource IconCheck}"
                              Stroke="White"
                              StrokeThickness="1.8"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="15" Height="15"
                              VerticalAlignment="Center" />
                        <TextBlock Text="حفظ الدرجات"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="إجمالي الطلاب"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding TotalCountText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="مُدخَلة"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding EnteredCountText}"
                               Foreground="{StaticResource InfoBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="ناجحون"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding PassedCountText}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="راسبون"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding FailedCountText}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="8" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="غير ممتحَن"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding MissingCountText}"
                               Foreground="{StaticResource WarningBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Style="{StaticResource CardBorder}"
                Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          IsReadOnly="False"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          KeyboardNavigation.TabNavigation="Continue"
                          Visibility="{Binding HasRows, Converter={StaticResource BoolToVisibility}}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الطالب"
                                            Binding="{Binding StudentNumber}"
                                            IsReadOnly="True"
                                            Width="130" />
                        <DataGridTextColumn Header="اسم الطالب"
                                            Binding="{Binding FullName}"
                                            IsReadOnly="True"
                                            Width="*" />

                        <DataGridTemplateColumn Header="الدرجة" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Value, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             MaxLength="6"
                                             MinHeight="30"
                                             Padding="6,2"
                                             VerticalContentAlignment="Center"
                                             TextAlignment="Center"
                                             ToolTip="{Binding MaxMark, StringFormat='الحد الأقصى: {0:N2}'}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsPassed}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="الحالة" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusLabel}"
                                               Style="{StaticResource MarkStatusText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ملاحظات" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="300"
                                             MinHeight="30"
                                             Padding="6,2"
                                             VerticalContentAlignment="Center"
                                             TextAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="#AAFFFFFF"
                        Visibility="{Binding HasRows, Converter={StaticResource InverseBoolToVisibility}}"
                        IsHitTestVisible="False">
                    <TextBlock Text="اختر الصف والشعبة والمادة والامتحان أو لا يوجد طلاب"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeBase}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <controls:LoadingOverlay Grid.RowSpan="4"
                                 IsBusy="{Binding IsLoading}"
                                 Message="جاري تحميل الدرجات…" />
    </Grid>
</UserControl>
