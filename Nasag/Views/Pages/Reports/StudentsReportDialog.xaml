<Window x:Class="Nasag.Views.Pages.Reports.StudentsReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Nasag.Controls"
        xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Reports"
        xmlns:helpers="clr-namespace:Nasag.Helpers"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:StudentsReportViewModel}"
        Style="{StaticResource BaseWindowStyle}"
        Title="تقرير الطلاب"
        Width="640"
        Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource TajawalFont}"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{x:Static SystemCommands.CloseWindowCommand}" />
        <KeyBinding Modifiers="Control" Key="P" Command="{Binding PreviewCommand}" />
    </Window.InputBindings>

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header (drag region) -->
            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Padding="22,18,22,12"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="22"
                                Background="{StaticResource TealSoftBrush}"
                                VerticalAlignment="Center">
                            <Path Data="{StaticResource IconStudents}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="22" Height="22" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="تقرير الطلاب"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="اختر معايير التصفية ثم اضغط معاينة أو تصدير"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Click="OnCancelClick"
                            ToolTip="إغلاق"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="22,4,22,18">
                <StackPanel>
                    <TextBlock Text="الصف (اختياري)" Style="{StaticResource FieldLabel}" />
                    <controls:SearchableComboBox ItemsSource="{Binding Grades}"
                                                 SelectedItem="{Binding SelectedGrade, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="كل الصفوف"
                                                 MinHeight="36"
                                                 Margin="0,0,0,12" />

                    <TextBlock Text="الشعبة (اختياري)" Style="{StaticResource FieldLabel}" />
                    <controls:SearchableComboBox ItemsSource="{Binding AvailableSections}"
                                                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                                                 DisplayMemberPath="DisplayName"
                                                 Placeholder="كل الشعب"
                                                 MinHeight="36"
                                                 Margin="0,0,0,12" />

                    <TextBlock Text="الحالة" Style="{StaticResource FieldLabel}" />
                    <controls:SearchableComboBox ItemsSource="{Binding StatusOptions}"
                                                 SelectedItem="{Binding SelectedStatus, Mode=TwoWay}"
                                                 DisplayMemberPath="DisplayName"
                                                 Placeholder="كل الحالات"
                                                 MinHeight="36"
                                                 Margin="0,0,0,12" />

                    <!-- Busy hint -->
                    <Border Background="{StaticResource InfoSoftBrush}"
                            CornerRadius="8"
                            Padding="10,6"
                            Margin="0,8,0,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="جاري المعالجة…"
                                   Foreground="{StaticResource InfoBrush}"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource GhostButton}"
                            Padding="18,8"
                            Margin="0,0,10,0"
                            Click="OnCancelClick"
                            Content="إغلاق"
                            IsCancel="True" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Padding="18,8"
                            Margin="0,0,10,0"
                            Command="{Binding ExportExcelCommand}"
                            Content="تصدير Excel" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Padding="18,8"
                            Margin="0,0,10,0"
                            Command="{Binding ExportPdfCommand}"
                            Content="تصدير PDF" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="22,8"
                            Command="{Binding PreviewCommand}"
                            Content="معاينة وطباعة"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
