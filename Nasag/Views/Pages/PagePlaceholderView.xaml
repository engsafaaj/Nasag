<UserControl x:Class="Nasag.Views.Pages.PagePlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             mc:Ignorable="d">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:SectionHeader Grid.Row="0"
                                HorizontalAlignment="Right"
                                Title="{Binding TitleAr}"
                                Subtitle="{Binding SubtitleAr}" />

        <Border Grid.Row="1" Style="{StaticResource CardBorderLg}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="{StaticResource TealSoftBrush}"
                        Width="80" Height="80"
                        CornerRadius="40">
                    <Path Data="M12 6 V14 M12 18 H12.01"
                          Stroke="{StaticResource TealPressedBrush}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="36" Height="36" />
                </Border>
                <TextBlock Text="لا توجد بيانات متاحة"
                           Style="{StaticResource SubheadTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,4" />
                <TextBlock Text="{Binding TitleAr}"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
