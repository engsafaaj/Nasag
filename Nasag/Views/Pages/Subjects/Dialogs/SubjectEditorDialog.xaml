<Window x:Class="Nasag.Views.Pages.Subjects.Dialogs.SubjectEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Nasag.Controls"
        mc:Ignorable="d"
        Style="{StaticResource BaseWindowStyle}"
        Title="نَسَق"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="22,18,22,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44"
                            CornerRadius="22"
                            Background="{StaticResource TealSoftBrush}"
                            VerticalAlignment="Center">
                        <Path Data="{StaticResource IconSubjects}"
                              Stroke="{StaticResource TealPressedBrush}"
                              StrokeThickness="1.8"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="22" Height="22" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   FontFamily="{StaticResource TajawalFont}"
                                   FontSize="{StaticResource FontSizeLg}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="إضافة مادة" />
                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Margin="0,2,0,0"
                                   Text="عرّف اسم المادة، الصف، والدرجات." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Padding="22,4,22,18">
                <StackPanel>
                    <TextBlock Text="اسم المادة" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="NameBox"
                             MaxLength="80"
                             Margin="0,0,0,12" />

                    <TextBlock Text="الصف" Style="{StaticResource FieldLabel}" />
                    <controls:SearchableComboBox x:Name="GradeBox"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="اختر الصف"
                                                 MinHeight="36"
                                                 Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="الدرجة الكاملة" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="MaxMarkBox"
                                     MaxLength="6" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="درجة النجاح" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="PassMarkBox"
                                     MaxLength="6" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="درجة النجاح يجب أن تكون بين 0 والدرجة الكاملة."
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}"
                               Margin="0,4,0,0" />

                    <TextBlock x:Name="ErrorText"
                               Style="{StaticResource MutedTextStyle}"
                               Foreground="{StaticResource DangerBrush}"
                               Margin="0,10,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource SecondaryButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Click="OnCancelClick"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Click="OnConfirmClick"
                            Content="حفظ"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
