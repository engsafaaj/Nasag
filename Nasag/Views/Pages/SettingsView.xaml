<UserControl x:Class="Nasag.Views.Pages.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             FlowDirection="RightToLeft">

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header — FlowDirection swap pins title to the visual-right unconditionally. -->
        <Grid Grid.Row="0" Margin="0,0,0,16" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleAr}"
                           Style="{StaticResource SectionTitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding SubtitleAr}"
                           Style="{StaticResource SectionSubtitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="720" HorizontalAlignment="Stretch">

                <!-- Card: list/grid preferences -->
                <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="عرض الطلاب"
                                   FontWeight="Bold"
                                   Style="{StaticResource SubheadTextStyle}" />
                        <TextBlock Text="تحكَّم في كيفية ترتيب قائمة الطلاب في الجدول الرئيسي."
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Margin="0,4,0,16" />

                        <Border BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,14,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ترتيب الطلاب أبجدياً"
                                               FontWeight="Medium"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="عند إيقاف الترتيب، يظهر الطالب المُضاف حديثاً في أعلى القائمة."
                                               Style="{StaticResource MutedTextStyle}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding StudentsSortAlphabetically}"
                                          VerticalAlignment="Center"
                                          Content="مُفعَّل" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
