<UserControl x:Class="Nasag.Views.Pages.Attendance.AttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Attendance"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AttendanceViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <Style x:Key="AttendanceRadio" TargetType="RadioButton">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="CompactMetricCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="MinHeight" Value="78" />
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveDayCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ReloadCommand}"
                    VerticalAlignment="Center"
                    Padding="14,8"
                    ToolTip="تحديث البيانات (F5)">
                <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                    <Path Data="{StaticResource IconRefresh}"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="14" Height="14"
                          VerticalAlignment="Center" />
                    <TextBlock Text="تحديث"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="2"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleAr}"
                           Style="{StaticResource SectionTitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding SubtitleAr}"
                           Style="{StaticResource SectionSubtitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="14,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="الصف"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding Grades}"
                                                 SelectedItem="{Binding SelectedGrade, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الصف" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="الشعبة"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding AvailableSections}"
                                                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الشعبة" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                    <TextBlock Text="التاريخ"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Margin="8,0,0,0">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding MarkAllPresentCommand}"
                            Padding="14,8"
                            ToolTip="تحديد الكل حاضر">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <Path Data="{StaticResource IconCheck}"
                                  Stroke="{StaticResource TealPrimaryBrush}"
                                  StrokeThickness="1.7"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="تحديد الكل حاضر"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Grid.Column="5"
                        Style="{StaticResource BubbleButton}"
                        Command="{Binding SaveDayCommand}"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0"
                        Padding="16,8"
                        ToolTip="حفظ الحضور (Ctrl+S)">
                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                        <Path Data="{StaticResource IconCheck}"
                              Stroke="White"
                              StrokeThickness="1.8"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="15" Height="15"
                              VerticalAlignment="Center" />
                        <TextBlock Text="حفظ الحضور"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="إجمالي الطلاب"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding TotalCountText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="الحاضرون"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding PresentCountText}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="الغائبون"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding AbsentCountText}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="المتأخرون"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding LateCountText}"
                               Foreground="{StaticResource WarningBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="8" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="في إجازة"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding ExcusedCountText}"
                               Foreground="{StaticResource InfoBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Style="{StaticResource CardBorder}"
                Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          IsReadOnly="False"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الطالب"
                                            Binding="{Binding StudentNumber}"
                                            IsReadOnly="True"
                                            Width="130" />
                        <DataGridTextColumn Header="اسم الطالب"
                                            Binding="{Binding FullName}"
                                            IsReadOnly="True"
                                            Width="2*" />

                        <DataGridTemplateColumn Header="حاضر" Width="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource AttendanceRadio}"
                                                 GroupName="{Binding StatusGroupName}"
                                                 IsChecked="{Binding IsPresent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="غائب" Width="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource AttendanceRadio}"
                                                 GroupName="{Binding StatusGroupName}"
                                                 IsChecked="{Binding IsAbsent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="متأخر" Width="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource AttendanceRadio}"
                                                 GroupName="{Binding StatusGroupName}"
                                                 IsChecked="{Binding IsLate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="إجازة" Width="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource AttendanceRadio}"
                                                 GroupName="{Binding StatusGroupName}"
                                                 IsChecked="{Binding IsExcused, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ملاحظات" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="300"
                                             MinHeight="30"
                                             VerticalContentAlignment="Center"
                                             TextAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="#AAFFFFFF"
                        Visibility="{Binding HasRows, Converter={StaticResource InverseBoolToVisibility}}"
                        IsHitTestVisible="False">
                    <TextBlock Text="لا توجد سجلات حضور"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeBase}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <controls:LoadingOverlay Grid.RowSpan="4"
                                 IsBusy="{Binding IsLoading}"
                                 Message="جاري تحميل الحضور…" />
    </Grid>
</UserControl>
