<Window x:Class="Nasag.Views.Pages.Exams.Dialogs.ExamEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Nasag.Controls"
        mc:Ignorable="d"
        Style="{StaticResource BaseWindowStyle}"
        Title="نَسَق"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="22,18,22,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44"
                            CornerRadius="22"
                            Background="{StaticResource TealSoftBrush}"
                            VerticalAlignment="Center">
                        <Path Data="{StaticResource IconSubjects}"
                              Stroke="{StaticResource TealPressedBrush}"
                              StrokeThickness="2"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="22" Height="22" />
                    </Border>
                    <TextBlock x:Name="TitleText"
                               FontFamily="{StaticResource TajawalFont}"
                               FontSize="{StaticResource FontSizeLg}"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               Text="إضافة امتحان" />
                </StackPanel>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="22,4,22,18">
                <StackPanel>
                    <TextBlock Text="اسم الامتحان" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="NameBox"
                             MaxLength="80"
                             Margin="0,0,0,4" />
                    <TextBlock Text="مثال: شهري 1، شهري 2، نصفي، نهائي."
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}"
                               Margin="0,4,0,12" />

                    <TextBlock Text="السنة الدراسية" Style="{StaticResource FieldLabel}" />
                    <controls:SearchableComboBox x:Name="YearBox"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="اختر السنة الدراسية"
                                                 MinHeight="36"
                                                 Margin="0,0,0,12" />

                    <TextBlock Text="الوزن" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="WeightBox"
                             MaxLength="6"
                             Margin="0,0,0,4" />
                    <TextBlock Text="رقم عشري بين 0.1 و 10 (يحدد ثقل هذا الامتحان في حساب المعدل)."
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}"
                               Margin="0,4,0,0" />

                    <TextBlock x:Name="ErrorText"
                               Style="{StaticResource MutedTextStyle}"
                               Foreground="{StaticResource DangerBrush}"
                               Margin="0,10,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="#F8FAFC"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource SecondaryButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Click="OnCancelClick"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Click="OnConfirmClick"
                            Content="حفظ"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
