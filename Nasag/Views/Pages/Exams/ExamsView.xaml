<UserControl x:Class="Nasag.Views.Pages.Exams.ExamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Exams"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ExamsViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding AddExamCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Page Header (FlowDirection swap) ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,14" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ReloadCommand}"
                    VerticalAlignment="Center"
                    Padding="14,8"
                    ToolTip="تحديث البيانات (F5)">
                <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                    <Path Data="{StaticResource IconRefresh}"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="14" Height="14"
                          VerticalAlignment="Center" />
                    <TextBlock Text="تحديث"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="2"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleAr}"
                           Style="{StaticResource SectionTitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding SubtitleAr}"
                           Style="{StaticResource SectionSubtitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="14,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="السنة الدراسية"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding Years}"
                                                 SelectedItem="{Binding SelectedYear, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="السنة الدراسية" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="بحث"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Tag="ابحث عن امتحان…" />
                </StackPanel>

                <Button Grid.Column="2"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ReloadCommand}"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0"
                        Padding="10,8"
                        ToolTip="تحديث">
                    <Path Data="{StaticResource IconRefresh}"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="14" Height="14" />
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearFiltersCommand}"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0"
                        Padding="10,8"
                        ToolTip="مسح الفلاتر">
                    <Path Data="{StaticResource IconFilterClear}"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="14" Height="14" />
                </Button>

                <Button Grid.Column="4"
                        Style="{StaticResource BubbleButton}"
                        Command="{Binding AddExamCommand}"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,0"
                        Padding="16,8"
                        ToolTip="إضافة امتحان (Ctrl+N)">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconAdd}"
                              Stroke="White"
                              StrokeThickness="2"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14"
                              VerticalAlignment="Center" />
                        <TextBlock Text="إضافة امتحان"
                                   Foreground="White"
                                   FontWeight="Medium"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== DataGrid ===== -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorder}"
                Padding="0">
            <Grid>
                <DataGrid x:Name="ExamsGrid"
                          ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          MouseDoubleClick="OnGridDoubleClick"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="الامتحان"
                                            Binding="{Binding NameAr}"
                                            Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="10,0,0,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="السنة الدراسية"
                                            Binding="{Binding AcademicYearName}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="الوزن"
                                            Binding="{Binding Weight, StringFormat=N2}"
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="عدد الدرجات"
                                            Binding="{Binding MarksCount}"
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="إجراءات" Width="120" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="6,2">
                                        <Button Style="{StaticResource RowActionButton}"
                                                ToolTip="تعديل الامتحان"
                                                Command="{Binding DataContext.EditExamCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="{StaticResource IconEdit}"
                                                  Stroke="{StaticResource TextSecondaryBrush}"
                                                  StrokeThickness="1.6"
                                                  Fill="Transparent"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <Button Style="{StaticResource RowActionButton}"
                                                Margin="6,0,0,0"
                                                ToolTip="حذف الامتحان"
                                                Command="{Binding DataContext.DeleteExamCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="{StaticResource IconDelete}"
                                                  Stroke="{StaticResource DangerBrush}"
                                                  StrokeThickness="1.6"
                                                  Fill="Transparent"
                                                  Stretch="Uniform" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="20">
                    <Border Background="{StaticResource TealSoftBrush}"
                            Width="56" Height="56"
                            CornerRadius="28"
                            HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconSubjects}"
                              Stroke="{StaticResource TealPressedBrush}"
                              StrokeThickness="1.7"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="24" Height="24" />
                    </Border>
                    <TextBlock Text="لا توجد امتحانات"
                               Style="{StaticResource SubheadTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0" />
                    <TextBlock Text="استخدم زر «إضافة امتحان» لإنشاء أول امتحان"
                               Style="{StaticResource CaptionTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <controls:LoadingOverlay Grid.RowSpan="3"
                                 IsBusy="{Binding IsLoading}"
                                 Message="جاري تحميل الامتحانات…" />
    </Grid>
</UserControl>
