<Window x:Class="Nasag.Views.Pages.Settings.AcademicYearDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Settings"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AcademicYearDialogViewModel}"
        Style="{StaticResource BaseWindowStyle}"
        Title="السنة الدراسية"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{x:Static ApplicationCommands.Close}" />
    </Window.InputBindings>

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header (drag region) -->
            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Padding="22,18,22,8"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="22"
                                Background="{StaticResource TealSoftBrush}"
                                VerticalAlignment="Center">
                            <Path Data="{StaticResource IconSettings}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="22" Height="22" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="حدّد الاسم وتاريخي البداية والنهاية."
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Click="OnCancelClick"
                            ToolTip="إغلاق"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="22,4,22,18">
                <StackPanel>
                    <TextBlock Text="اسم السنة الدراسية" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="NameBox"
                             Text="{Binding NameAr, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="60"
                             Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="تاريخ البداية" Style="{StaticResource FieldLabel}" />
                            <DatePicker SelectedDate="{Binding StartDate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="تاريخ النهاية" Style="{StaticResource FieldLabel}" />
                            <DatePicker SelectedDate="{Binding EndDate}" />
                        </StackPanel>
                    </Grid>

                    <!-- Error banner -->
                    <Border Background="{StaticResource DangerSoftBrush}"
                            BorderBrush="{StaticResource DangerBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,6"
                            Margin="0,4,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource GhostButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Click="OnCancelClick"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Click="OnConfirmClick"
                            Content="حفظ"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
