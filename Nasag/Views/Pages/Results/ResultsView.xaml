<UserControl x:Class="Nasag.Views.Pages.Results.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Results"
             xmlns:svc="clr-namespace:Nasag.Services"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ResultsViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

        <Style x:Key="CompactMetricCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="MinHeight" Value="78" />
        </Style>

        <Style x:Key="GradePill" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Excellent}">
                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.VeryGood}">
                    <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Good}">
                    <Setter Property="Background" Value="{StaticResource TealSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Acceptable}">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Pending}">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Failed}">
                    <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GradePillText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Excellent}">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.VeryGood}">
                    <Setter Property="Foreground" Value="{StaticResource InfoBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Good}">
                    <Setter Property="Foreground" Value="{StaticResource TealPressedBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Acceptable}">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Pending}">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Failed}">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPassed}" Value="True">
                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Pending}">
                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusPillText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPassed}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Grade}" Value="{x:Static svc:ResultGrade.Pending}">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ReloadCommand}"
                    VerticalAlignment="Center"
                    Padding="14,8"
                    ToolTip="تحديث البيانات (F5)">
                <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                    <Path Data="{StaticResource IconRefresh}"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="14" Height="14"
                          VerticalAlignment="Center" />
                    <TextBlock Text="تحديث"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ClearFiltersCommand}"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Padding="14,8"
                    ToolTip="مسح الفلاتر">
                <TextBlock Text="مسح الفلاتر" VerticalAlignment="Center" />
            </Button>

            <StackPanel Grid.Column="3"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleAr}"
                           Style="{StaticResource SectionTitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding SubtitleAr}"
                           Style="{StaticResource SectionSubtitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="14,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="الصف"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding Grades}"
                                                 SelectedItem="{Binding SelectedGrade, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الصف" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="الشعبة"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding AvailableSections}"
                                                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الشعبة" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                    <TextBlock Text="السنة الدراسية"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding Years}"
                                                 SelectedItem="{Binding SelectedYear, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="السنة" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="8,0,0,0">
                    <TextBlock Text="بحث"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             MinHeight="34" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stat cards (6 cards: Total, Passed, Failed, Pending, Highest, Lowest) -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="إجمالي الطلاب"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding TotalCountText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="الناجحون"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding PassedCountText}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="الراسبون"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding FailedCountText}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="غير مكتمل"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding PendingCountText}"
                               Foreground="{StaticResource WarningBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="8" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="أعلى معدل"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding HighestPercentageText}"
                               Foreground="{StaticResource InfoBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="10" Style="{StaticResource CompactMetricCard}">
                <StackPanel>
                    <TextBlock Text="أدنى معدل"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding LowestPercentageText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="3"
                Style="{StaticResource CardBorder}"
                Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الطالب"
                                            Binding="{Binding StudentNumber}"
                                            IsReadOnly="True"
                                            Width="130" />
                        <DataGridTextColumn Header="اسم الطالب"
                                            Binding="{Binding FullName}"
                                            IsReadOnly="True"
                                            Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="المجموع"
                                            Binding="{Binding TotalDisplay}"
                                            IsReadOnly="True"
                                            Width="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="ToolTip" Value="{Binding TotalTooltip}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="النسبة المئوية"
                                            Binding="{Binding PercentageDisplay}"
                                            IsReadOnly="True"
                                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="التقدير" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GradePill}">
                                        <TextBlock Text="{Binding GradeLabelAr}"
                                                   Style="{StaticResource GradePillText}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="الحالة" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatusPill}">
                                        <TextBlock Text="{Binding StatusLabelAr}"
                                                   Style="{StaticResource StatusPillText}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="{StaticResource OverlayBrush}"
                        Visibility="{Binding HasRows, Converter={StaticResource InverseBoolToVisibility}}"
                        IsHitTestVisible="False">
                    <TextBlock Text="اختر الصف والشعبة والسنة لعرض النتائج"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeBase}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <controls:LoadingOverlay Grid.RowSpan="4"
                                 IsBusy="{Binding IsLoading}"
                                 Message="جاري تحميل النتائج…" />
    </Grid>
</UserControl>
