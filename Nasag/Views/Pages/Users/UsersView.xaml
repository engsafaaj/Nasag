<UserControl x:Class="Nasag.Views.Pages.Users.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Users"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:UsersViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:DateToRelativeArabicConverter x:Key="RelativeDate" />
    </UserControl.Resources>

    <!--
        Keyboard shortcuts:
        - Ctrl+N : add user
        - F5     : reload
        - Delete : delete the currently selected row
        - Ctrl+F : focus the search box (wired in code-behind)
    -->
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding AddCommand}" />
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedRow}" />
    </UserControl.InputBindings>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header (FlowDirection swap pattern, AI_INSTRUCTIONS §1) ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,14" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleAr}"
                           Style="{StaticResource SectionTitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding StatsLine}"
                           Style="{StaticResource SectionSubtitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="14,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <controls:SearchableComboBox Grid.Column="0"
                                             ItemsSource="{Binding RoleOptions}"
                                             SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                             DisplayMemberPath="NameAr"
                                             Placeholder="الدور"
                                             MinWidth="160" />

                <CheckBox Grid.Column="1"
                          Content="النشطون فقط"
                          IsChecked="{Binding ActiveOnly, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Margin="12,0,0,0" />

                <Border Grid.Column="2"
                        Background="{StaticResource BackgroundBrush}"
                        CornerRadius="{StaticResource RadiusSm}"
                        Padding="10,2"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        MinWidth="180"
                        MaxWidth="380"
                        Margin="12,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconSearch}"
                              Stroke="{StaticResource TextMutedBrush}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="16" Height="16"
                              VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 x:Name="SearchBox"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MinHeight="30"
                                 VerticalContentAlignment="Center"
                                 Margin="8,0,0,0"
                                 ToolTip="بحث بالاسم أو اسم المستخدم أو الجوال (Ctrl+F)" />
                    </Grid>
                </Border>

                <Button Grid.Column="3"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ReloadCommand}"
                        Margin="8,0,0,0"
                        Padding="10,6"
                        ToolTip="تحديث (F5)">
                    <Path Data="{StaticResource IconRefresh}"
                          Stroke="{StaticResource TextPrimaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="14" Height="14" />
                </Button>

                <Button Grid.Column="4"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding ClearFiltersCommand}"
                        Margin="6,0,0,0"
                        Padding="10,6"
                        ToolTip="مسح الفلاتر">
                    <Path Data="{StaticResource IconFilterClear}"
                          Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="14" Height="14" />
                </Button>

                <Button Grid.Column="5"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ManageRolesCommand}"
                        Margin="8,0,0,0"
                        Padding="12,6"
                        ToolTip="إدارة الأدوار والصلاحيات">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconLock}"
                              Stroke="{StaticResource TealPressedBrush}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14"
                              VerticalAlignment="Center" />
                        <TextBlock Text="إدارة الأدوار"
                                   Foreground="{StaticResource TealPressedBrush}"
                                   FontWeight="Medium"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== DataGrid card ===== -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <Grid>
                <DataGrid x:Name="UsersGrid"
                          ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}"
                          MouseDoubleClick="OnRowDoubleClick"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"
                                            Binding="{Binding Id}"
                                            Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="الاسم الكامل"
                                            Binding="{Binding FullName}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="اسم المستخدم"
                                            Binding="{Binding Username}"
                                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="الدور"
                                            Binding="{Binding RoleNameAr}"
                                            Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="الحالة" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Center" Margin="6,4">
                                        <Border Style="{StaticResource SuccessPill}"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="نشط" Style="{StaticResource SuccessPillText}" />
                                        </Border>
                                        <Border Style="{StaticResource DangerPill}">
                                            <Border.Visibility>
                                                <Binding Path="IsActive">
                                                    <Binding.Converter>
                                                        <helpers:InverseBoolToVisibilityConverter />
                                                    </Binding.Converter>
                                                </Binding>
                                            </Border.Visibility>
                                            <TextBlock Text="موقوف" Style="{StaticResource DangerPillText}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="تاريخ الإنشاء"
                                            Binding="{Binding CreatedAt, Converter={StaticResource RelativeDate}}"
                                            Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="آخر دخول"
                                            Binding="{Binding LastLoginAt, Converter={StaticResource RelativeDate}}"
                                            Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="إجراءات" Width="220" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="6,2">
                                        <Button Style="{StaticResource RowActionButton}"
                                                ToolTip="تعديل"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="{StaticResource IconEdit}"
                                                  Stroke="{StaticResource TextSecondaryBrush}"
                                                  StrokeThickness="1.6"
                                                  Fill="Transparent"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <Button Style="{StaticResource RowActionButton}"
                                                Margin="6,0,0,0"
                                                ToolTip="إعادة تعيين كلمة المرور"
                                                Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="{StaticResource IconLock}"
                                                  Stroke="{StaticResource WarningBrush}"
                                                  StrokeThickness="1.6"
                                                  Fill="Transparent"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <Button Style="{StaticResource RowActionButton}"
                                                Margin="6,0,0,0"
                                                ToolTip="تفعيل / إيقاف"
                                                Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="{StaticResource IconCheck}"
                                                  Stroke="{StaticResource SuccessBrush}"
                                                  StrokeThickness="1.6"
                                                  Fill="Transparent"
                                                  Stretch="Uniform" />
                                        </Button>
                                        <Button Style="{StaticResource RowActionButton}"
                                                Margin="6,0,0,0"
                                                ToolTip="حذف"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="{StaticResource IconDelete}"
                                                  Stroke="{StaticResource DangerBrush}"
                                                  StrokeThickness="1.6"
                                                  Fill="Transparent"
                                                  Stretch="Uniform" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,40">
                    <Border Background="{StaticResource TealSoftBrush}"
                            Width="64" Height="64"
                            CornerRadius="32"
                            HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconUsers}"
                              Stroke="{StaticResource TealPressedBrush}"
                              StrokeThickness="1.7"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="28" Height="28" />
                    </Border>
                    <TextBlock Text="لا توجد نتائج مطابقة"
                               Style="{StaticResource SubheadTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />
                    <TextBlock Text="جرّب تعديل الفلاتر أو إضافة مستخدم جديد"
                               Style="{StaticResource CaptionTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!--
            Floating Action Button — overlay over Row 2 (DataGrid card). FlowDirection
            swap forces HorizontalAlignment="Right" to mean the literal right edge.
        -->
        <Grid Grid.Row="2" FlowDirection="LeftToRight">
            <Button Style="{StaticResource FabButton}"
                    Command="{Binding AddCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,28,28"
                    Visibility="{Binding CanManageUsers, Converter={StaticResource BoolToVisibility}}"
                    ToolTip="إضافة مستخدم (Ctrl+N)">
                <Path Data="{StaticResource IconAdd}"
                      Stroke="White"
                      StrokeThickness="2.6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"
                      Stretch="Uniform"
                      Width="24" Height="24" />
            </Button>
        </Grid>

        <controls:LoadingOverlay Grid.Row="0" Grid.RowSpan="3"
                                 IsBusy="{Binding IsLoading}"
                                 Message="جاري تحميل المستخدمين…" />
    </Grid>
</UserControl>
