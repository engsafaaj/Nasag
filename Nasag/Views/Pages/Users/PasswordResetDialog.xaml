<Window x:Class="Nasag.Views.Pages.Users.PasswordResetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:helpers="clr-namespace:Nasag.Helpers"
        xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Users"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:PasswordResetDialogViewModel}"
        Style="{StaticResource BaseWindowStyle}"
        Title="إعادة تعيين كلمة المرور"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Key="Enter" Command="{Binding SaveCommand}" />
    </Window.InputBindings>

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Padding="22,18,22,8"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="22"
                                Background="{StaticResource WarningSoftBrush}"
                                VerticalAlignment="Center">
                            <Path Data="{StaticResource IconLock}"
                                  Stroke="{StaticResource WarningBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="20" Height="20" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="إعادة تعيين كلمة المرور"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding TargetUserName}"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Command="{Binding CancelCommand}"
                            ToolTip="إغلاق"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="22,4,22,18">
                <StackPanel>
                    <CheckBox x:Name="ShowToggle"
                              Content="إظهار كلمات المرور"
                              Margin="0,0,0,12"
                              Checked="OnShowToggleChanged"
                              Unchecked="OnShowToggleChanged" />

                    <TextBlock Text="كلمة المرور الجديدة" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,12">
                        <PasswordBox x:Name="NewPasswordBox"
                                     PasswordChanged="OnNewPasswordChanged"
                                     MaxLength="60" />
                        <TextBox x:Name="NewPasswordPlain"
                                 Visibility="Collapsed"
                                 TextChanged="OnNewPlainChanged"
                                 MaxLength="60" />
                    </Grid>

                    <TextBlock Text="تأكيد كلمة المرور" Style="{StaticResource FieldLabel}" />
                    <Grid Margin="0,0,0,4">
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     PasswordChanged="OnConfirmPasswordChanged"
                                     MaxLength="60" />
                        <TextBox x:Name="ConfirmPasswordPlain"
                                 Visibility="Collapsed"
                                 TextChanged="OnConfirmPlainChanged"
                                 MaxLength="60" />
                    </Grid>

                    <TextBlock Text="6 أحرف فأكثر."
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,6,0,0" />

                    <Border Background="{StaticResource DangerSoftBrush}"
                            BorderBrush="{StaticResource DangerBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,6"
                            Margin="0,10,0,0"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource GhostButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Command="{Binding CancelCommand}"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding CanSave}"
                            Content="حفظ كلمة المرور"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
