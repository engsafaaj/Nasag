<Window x:Class="Nasag.Views.Pages.Users.UserEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Nasag.Controls"
        xmlns:helpers="clr-namespace:Nasag.Helpers"
        xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Users"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:UserEditorDialogViewModel}"
        Style="{StaticResource BaseWindowStyle}"
        Title="مستخدم"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
    </Window.InputBindings>

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ============== Header (drag region) ============== -->
            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Padding="22,18,22,8"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="46" Height="46"
                                CornerRadius="23"
                                Background="{StaticResource TealSoftBrush}"
                                VerticalAlignment="Center">
                            <Path Data="{StaticResource IconUser}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="22" Height="22" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TitleAr}"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="املأ بيانات الحساب ثم اضغط حفظ."
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Command="{Binding CancelCommand}"
                            ToolTip="إغلاق"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- ============== Body ============== -->
            <Border Grid.Row="1" Padding="22,4,22,18">
                <StackPanel>
                    <TextBlock Text="الاسم الكامل" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="80"
                             Margin="0,0,0,12" />

                    <TextBlock Text="اسم المستخدم" Style="{StaticResource FieldLabel}" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="60"
                             IsEnabled="{Binding IsAddMode}"
                             ToolTip="لا يمكن تغيير اسم المستخدم بعد إنشاء الحساب."
                             Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="البريد الإلكتروني" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="120" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="رقم الجوال" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="20" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="الدور" Style="{StaticResource FieldLabel}" />
                    <controls:SearchableComboBox ItemsSource="{Binding Roles}"
                                                 SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="اختر الدور"
                                                 MinHeight="36"
                                                 Margin="0,0,0,12" />

                    <CheckBox Content="حساب نشط"
                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                              Margin="0,4,0,12" />

                    <!-- Password fields appear only in Add mode -->
                    <StackPanel Visibility="{Binding IsAddMode, Converter={StaticResource BoolToVisibility}}">
                        <Border Background="{StaticResource BackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="كلمة المرور" Style="{StaticResource FieldLabel}" />
                                <PasswordBox x:Name="NewPasswordBox"
                                             PasswordChanged="OnNewPasswordChanged"
                                             MaxLength="60"
                                             Margin="0,0,0,10" />
                                <TextBlock Text="تأكيد كلمة المرور" Style="{StaticResource FieldLabel}" />
                                <PasswordBox x:Name="ConfirmPasswordBox"
                                             PasswordChanged="OnConfirmPasswordChanged"
                                             MaxLength="60" />
                                <TextBlock Text="6 أحرف فأكثر."
                                           Style="{StaticResource MutedTextStyle}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Error banner -->
                    <Border Background="{StaticResource DangerSoftBrush}"
                            BorderBrush="{StaticResource DangerBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,6"
                            Margin="0,4,0,0"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============== Footer ============== -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource GhostButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Command="{Binding CancelCommand}"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding CanSave}"
                            Content="حفظ"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
