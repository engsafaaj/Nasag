<Window x:Class="Nasag.Views.Pages.Backup.BackupNotesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Style="{StaticResource BaseWindowStyle}"
        Title="ملاحظات النسخة الاحتياطية"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header (drag region) -->
            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Padding="22,18,22,8"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="22"
                                Background="{StaticResource TealSoftBrush}"
                                VerticalAlignment="Center">
                            <Path Data="{StaticResource IconBackup}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="22" Height="22" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ملاحظات النسخة الاحتياطية"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="أضف وصفاً مختصراً يساعدك على تمييز هذه النسخة لاحقاً"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Click="OnCancelClick"
                            ToolTip="إغلاق"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="22,4,22,18">
                <StackPanel>
                    <TextBlock Text="ملاحظات (اختياري)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="NotesBox"
                             MaxLength="300"
                             Height="90"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             Margin="0,0,0,4" />
                    <TextBlock Text="حد أقصى 300 حرف."
                               Style="{StaticResource CaptionTextStyle}"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource GhostButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Click="OnCancelClick"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Click="OnConfirmClick"
                            Content="بدء النسخ الاحتياطي"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
