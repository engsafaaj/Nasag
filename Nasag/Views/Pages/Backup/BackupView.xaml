<UserControl x:Class="Nasag.Views.Pages.Backup.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Backup"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BackupViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <!-- Page-local converters (NOT registered in Converters.xaml — only this view uses them) -->
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:DateToRelativeArabicConverter x:Key="DateToRelativeArabic" />
        <helpers:BytesToFileSizeConverter x:Key="BytesToFileSize" />
        <helpers:BackupKindToArabicConverter x:Key="BackupKindToArabic" />
        <helpers:BackupKindToBackgroundConverter x:Key="BackupKindToBackground" />
        <helpers:BackupKindToForegroundConverter x:Key="BackupKindToForeground" />
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid Margin="22,18,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--
                ===== Header =====
                FlowDirection swap so column 1 is anchored to the actual visual right.
            -->
            <Grid Grid.Row="0" Margin="0,0,0,14" FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1"
                            FlowDirection="RightToLeft"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleAr}"
                               Style="{StaticResource SectionTitle}"
                               TextAlignment="Right"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding SubtitleAr}"
                               Style="{StaticResource SectionSubtitle}"
                               TextAlignment="Right"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>

            <!--
                ===== Toolbar =====
                Single-row card with: folder label/path | refresh | create | restore.
                Visual order (RTL: leftmost column index = visual right):
                  0  "مجلد النسخ:" label  (visual right)
                  1  path TextBlock (clickable → folder picker)
                  2  spacer (*)
                  3  refresh icon button
                  4  Primary "إنشاء نسخة احتياطية"
                  5  Secondary danger-soft "استعادة من ملف"   (visual left)
            -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Padding="14,10"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="مجلد النسخ:"
                               Style="{StaticResource FieldLabel}"
                               VerticalAlignment="Center"
                               Margin="0,0,0,0" />

                    <Button Grid.Column="1"
                            Command="{Binding ChooseFolderCommand}"
                            Margin="8,0,0,0"
                            HorizontalContentAlignment="Right"
                            ToolTip="اضغط لاختيار مجلد آخر">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M3 7 H10 L12 5 H21 V19 H3 Z"
                                  Stroke="{StaticResource InfoBrush}"
                                  StrokeThickness="1.6"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="16" Height="16"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding BackupFolder, FallbackValue='—'}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- spacer column (Width=Auto next button) -->

                    <Button Grid.Column="2"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ReloadCommand}"
                            Margin="8,0,0,0"
                            Padding="10,6"
                            ToolTip="تحديث القائمة (F5)">
                        <Path Data="{StaticResource IconRefresh}"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14" />
                    </Button>

                    <Button Grid.Column="3"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateBackupCommand}"
                            Margin="8,0,0,0"
                            Padding="14,8"
                            ToolTip="إنشاء نسخة احتياطية الآن">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 4 V14 M8 10 L12 14 L16 10 M5 18 H19 M4 14 a8 8 0 1 0 16 0"
                                  Stroke="White"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="16" Height="16"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="إنشاء نسخة احتياطية"
                                       Foreground="White"
                                       FontWeight="Medium"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Command="{Binding RestoreBackupCommand}"
                            Margin="8,0,0,0"
                            Padding="14,8"
                            ToolTip="استعادة من ملف .bak">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 20 V10 M8 14 L12 10 L16 14 M5 6 H19 M4 10 a8 8 0 1 1 16 0"
                                  Stroke="{StaticResource DangerBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="16" Height="16"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="استعادة من ملف"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontWeight="Medium"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ===== DataGrid card ===== -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <DataGrid x:Name="BackupsGrid"
                              ItemsSource="{Binding Backups}"
                              Visibility="{Binding HasBackups, Converter={StaticResource BoolToVisibility}}"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              AutoGenerateColumns="False"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Binding="{Binding Id}"
                                                Width="64">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="Medium" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="النوع" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="999"
                                                Padding="10,3"
                                                Margin="6,4"
                                                HorizontalAlignment="Center"
                                                Background="{Binding Kind, Converter={StaticResource BackupKindToBackground}}">
                                            <TextBlock Text="{Binding Kind, Converter={StaticResource BackupKindToArabic}}"
                                                       Foreground="{Binding Kind, Converter={StaticResource BackupKindToForeground}}"
                                                       FontSize="{StaticResource FontSizeSm}"
                                                       FontWeight="Medium" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="مسار الملف"
                                                Binding="{Binding FilePath}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding FilePath}" />
                                        <Setter Property="Padding" Value="8,0" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="الحجم"
                                                Binding="{Binding SizeBytes, Converter={StaticResource BytesToFileSize}}"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="تاريخ الإنشاء"
                                                Binding="{Binding CreatedAt, Converter={StaticResource DateToRelativeArabic}}"
                                                Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="بواسطة"
                                                Binding="{Binding CreatedByName}"
                                                Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="ملاحظات"
                                                Binding="{Binding Notes}"
                                                Width="220">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="Padding" Value="8,0" />
                                        <Setter Property="ToolTip" Value="{Binding Notes}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="إجراءات" Width="120" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="6,2">
                                            <Button Style="{StaticResource RowActionButton}"
                                                    ToolTip="فتح موقع الملف"
                                                    Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="M3 7 H10 L12 5 H21 V19 H3 Z"
                                                      Stroke="{StaticResource InfoBrush}"
                                                      StrokeThickness="1.6"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                            <Button Style="{StaticResource RowActionButton}"
                                                    Margin="6,0,0,0"
                                                    ToolTip="حذف من السجل"
                                                    Command="{Binding DataContext.DeleteLogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconDelete}"
                                                      Stroke="{StaticResource DangerBrush}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,40">
                        <Border Background="{StaticResource TealSoftBrush}"
                                Width="64" Height="64"
                                CornerRadius="32"
                                HorizontalAlignment="Center">
                            <Path Data="{StaticResource IconBackup}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="1.7"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="28" Height="28" />
                        </Border>
                        <TextBlock Text="لا توجد نسخ احتياطية بعد"
                                   Style="{StaticResource SubheadTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="استخدم زر «إنشاء نسخة احتياطية» لحفظ أول نسخة من قاعدة البيانات."
                                   Style="{StaticResource CaptionTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <controls:LoadingOverlay IsBusy="{Binding IsLoading}" Message="جاري تحميل سجل النسخ الاحتياطي…" />
    </Grid>
</UserControl>
