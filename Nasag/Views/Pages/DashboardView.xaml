<UserControl x:Class="Nasag.Views.Pages.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:svc="clr-namespace:Nasag.Services"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <helpers:ActivityKindToBrushConverter x:Key="ActivityKindToBrush" />
        <helpers:ActivityKindToIconConverter x:Key="ActivityKindToIcon" />
        <helpers:DateToRelativeArabicConverter x:Key="DateToRelative" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--
                    Header row — uses FlowDirection=LeftToRight to take RTL mirroring
                    out of the picture. Column 2 is the *actual* right edge, so the
                    title StackPanel (with its own inner FlowDirection=RightToLeft for
                    Arabic text shaping) is pinned to the visual right unconditionally.
                -->
                <Grid Grid.Row="0" Margin="0,0,0,18" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshCommand}"
                            VerticalAlignment="Center"
                            FlowDirection="RightToLeft">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconRefresh}"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.6"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="تحديث"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="2"
                                FlowDirection="RightToLeft"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding TitleAr}"
                                   Style="{StaticResource SectionTitle}"
                                   TextAlignment="Right"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding SubtitleAr}"
                                   Style="{StaticResource SectionSubtitle}"
                                   TextAlignment="Right"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <!-- ===================== Stat cards row ===================== -->
                <UniformGrid Grid.Row="1" Columns="5" Rows="1" Margin="0,0,0,18">
                    <UniformGrid.Resources>
                        <Style TargetType="controls:StatCard">
                            <Setter Property="Margin" Value="0,0,12,0" />
                        </Style>
                    </UniformGrid.Resources>

                    <controls:StatCard Label="عدد الطلاب"
                                       Value="{Binding ActiveStudentsCount, StringFormat={}{0:N0}}"
                                       Hint="نشطون في السنة الحالية"
                                       AccentBrush="{StaticResource TealSoftBrush}"
                                       IconBrush="{StaticResource TealPressedBrush}"
                                       IconGeometry="{StaticResource IconStudents}" />

                    <controls:StatCard Label="عدد الشعب"
                                       Value="{Binding SectionsCount, StringFormat={}{0:N0}}"
                                       Hint="شعبة دراسية"
                                       AccentBrush="{StaticResource InfoSoftBrush}"
                                       IconBrush="{StaticResource InfoBrush}"
                                       IconGeometry="{StaticResource IconClasses}" />

                    <controls:StatCard Label="عدد المواد"
                                       Value="{Binding SubjectsCount, StringFormat={}{0:N0}}"
                                       Hint="موزّعة على الصفوف"
                                       AccentBrush="#EEF1FB"
                                       IconBrush="{StaticResource NavyDeepBrush}"
                                       IconGeometry="{StaticResource IconSubjects}" />

                    <controls:StatCard Label="غياب اليوم"
                                       Value="{Binding TodayAbsentCount, StringFormat={}{0:N0}}"
                                       Hint="طلاب مسجَّل غيابهم"
                                       AccentBrush="{StaticResource DangerSoftBrush}"
                                       IconBrush="{StaticResource DangerBrush}"
                                       IconGeometry="{StaticResource IconAttendance}" />

                    <controls:StatCard Label="الإيرادات (المحصّل)"
                                       Value="{Binding TotalCollectedFormatted}"
                                       Hint="ر.ي مستلمة من رسوم الطلاب"
                                       AccentBrush="{StaticResource SuccessSoftBrush}"
                                       IconBrush="{StaticResource SuccessBrush}"
                                       IconGeometry="{StaticResource IconFees}" />
                </UniformGrid>

                <!-- ===================== Charts row ===================== -->
                <Grid Grid.Row="2" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Attendance line chart -->
                    <Border Grid.Column="0"
                            Style="{StaticResource CardBorder}"
                            Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="نسبة الحضور خلال آخر 7 أيام"
                                               Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="نسبة الطلاب الحاضرين من إجمالي السجلات اليومية"
                                               Style="{StaticResource MutedTextStyle}"
                                               FontSize="{StaticResource FontSizeSm}" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{StaticResource TealSoftBrush}"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="10,4"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="آخر 7 أيام"
                                               Foreground="{StaticResource TealPressedBrush}"
                                               FontFamily="{StaticResource TajawalFont}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               FontWeight="Medium" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Height="240" FlowDirection="LeftToRight">
                                <lvc:CartesianChart Series="{Binding AttendanceSeries}"
                                                    XAxes="{Binding AttendanceXAxes}"
                                                    YAxes="{Binding AttendanceYAxes}"
                                                    LegendPosition="Hidden" />
                                <Border Background="{StaticResource CardSurfaceBrush}"
                                        Visibility="{Binding HasAttendanceHistory, Converter={StaticResource InverseBoolToVisibility}}"
                                        Opacity="0.85">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                FlowDirection="RightToLeft">
                                        <TextBlock Text="لا توجد سجلات حضور بعد"
                                                   Style="{StaticResource SubheadTextStyle}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="ابدأ بتسجيل الحضور اليومي لتظهر النسب هنا"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Today donut + breakdown -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="حضور اليوم"
                                           Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="موزّع حسب الحالة"
                                           Style="{StaticResource MutedTextStyle}"
                                           FontSize="{StaticResource FontSizeSm}" />
                            </StackPanel>

                            <Grid Grid.Row="1" Height="200" FlowDirection="LeftToRight">
                                <lvc:PieChart Series="{Binding TodayDonutSeries}"
                                              LegendPosition="Hidden"
                                              InitialRotation="-90" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            IsHitTestVisible="False"
                                            FlowDirection="RightToLeft">
                                    <TextBlock Text="{Binding TodayPresentPercent, StringFormat={}{0:0.#}٪}"
                                               FontFamily="{StaticResource TajawalFont}"
                                               FontSize="{StaticResource FontSize2xl}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="حضور"
                                               Style="{StaticResource CaptionTextStyle}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <UniformGrid Grid.Row="2" Columns="2" Rows="2" Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Border Width="10" Height="10" CornerRadius="5"
                                            Background="{StaticResource SuccessBrush}"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}">
                                        <Run Text="حاضر" />
                                        <Run Text=" " />
                                        <Run Text="{Binding TodayPresent, Mode=OneWay, StringFormat={}{0:N0}}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             FontWeight="Bold" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Border Width="10" Height="10" CornerRadius="5"
                                            Background="{StaticResource DangerBrush}"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}">
                                        <Run Text="غائب" />
                                        <Run Text=" " />
                                        <Run Text="{Binding TodayAbsent, Mode=OneWay, StringFormat={}{0:N0}}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             FontWeight="Bold" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Border Width="10" Height="10" CornerRadius="5"
                                            Background="{StaticResource WarningBrush}"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}">
                                        <Run Text="متأخر" />
                                        <Run Text=" " />
                                        <Run Text="{Binding TodayLate, Mode=OneWay, StringFormat={}{0:N0}}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             FontWeight="Bold" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Border Width="10" Height="10" CornerRadius="5"
                                            Background="{StaticResource InfoBrush}"
                                            VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource MutedTextStyle}">
                                        <Run Text="إجازة" />
                                        <Run Text=" " />
                                        <Run Text="{Binding TodayExcused, Mode=OneWay, StringFormat={}{0:N0}}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             FontWeight="Bold" />
                                    </TextBlock>
                                </StackPanel>
                            </UniformGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== Alerts + Recent activities ===================== -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <!-- Alerts column -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="44" Height="44" CornerRadius="12"
                                        Background="{StaticResource DangerSoftBrush}"
                                        VerticalAlignment="Top">
                                    <Path Data="{StaticResource IconFees}"
                                          Stroke="{StaticResource DangerBrush}"
                                          StrokeThickness="1.7"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="22" Height="22" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="أقساط متأخرة"
                                               Style="{StaticResource BodyTextStyle}"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding OverdueInstallments, StringFormat={}{0:N0} قسط لم يُسدَّد بعد موعد الاستحقاق}"
                                               Style="{StaticResource MutedTextStyle}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="44" Height="44" CornerRadius="12"
                                        Background="{StaticResource WarningSoftBrush}"
                                        VerticalAlignment="Top">
                                    <Path Data="{StaticResource IconCalendar}"
                                          Stroke="{StaticResource WarningBrush}"
                                          StrokeThickness="1.7"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="22" Height="22" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="مستحقات هذا الأسبوع"
                                               Style="{StaticResource BodyTextStyle}"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding DueThisWeekInstallments, StringFormat={}{0:N0} قسط يُستحق خلال الأيام السبعة القادمة}"
                                               Style="{StaticResource MutedTextStyle}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="44" Height="44" CornerRadius="12"
                                        Background="{StaticResource InfoSoftBrush}"
                                        VerticalAlignment="Top">
                                    <Path Data="{StaticResource IconAttendance}"
                                          Stroke="{StaticResource InfoBrush}"
                                          StrokeThickness="1.7"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="22" Height="22" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="حضور لم يُسجَّل اليوم"
                                               Style="{StaticResource BodyTextStyle}"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding StudentsWithoutAttendanceToday, StringFormat={}{0:N0} طالب بحاجة إلى تسجيل حضور اليوم}"
                                               Style="{StaticResource MutedTextStyle}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="44" Height="44" CornerRadius="12"
                                        Background="{StaticResource SuccessSoftBrush}"
                                        VerticalAlignment="Top">
                                    <Path Data="{StaticResource IconReports}"
                                          Stroke="{StaticResource SuccessBrush}"
                                          StrokeThickness="1.7"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="22" Height="22" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="الرسوم المتبقية"
                                               Style="{StaticResource BodyTextStyle}"
                                               FontWeight="Bold" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0">
                                        <Run Text="{Binding TotalRemainingFormatted, Mode=OneWay}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             FontWeight="Bold" />
                                        <Run Text=" ر.ي مستحقّة على أولياء الأمور" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Recent activities -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="آخر الأنشطة"
                                           Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="أحدث ما حدث في النظام"
                                           Style="{StaticResource MutedTextStyle}"
                                           FontSize="{StaticResource FontSizeSm}" />
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <ItemsControl ItemsSource="{Binding RecentActivities}"
                                              Visibility="{Binding HasRecentActivities, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type svc:RecentActivity}">
                                            <Border Padding="0,10"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Width="36" Height="36" CornerRadius="10"
                                                            Background="{Binding Kind, Converter={StaticResource ActivityKindToBrush}}"
                                                            VerticalAlignment="Center">
                                                        <Path Data="{Binding Kind, Converter={StaticResource ActivityKindToIcon}}"
                                                              Stroke="White"
                                                              StrokeThickness="1.7"
                                                              Fill="Transparent"
                                                              Stretch="Uniform"
                                                              Width="18" Height="18" />
                                                    </Border>

                                                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource BodyTextStyle}"
                                                                   FontWeight="Medium"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   Style="{StaticResource MutedTextStyle}"
                                                                   FontSize="{StaticResource FontSizeSm}"
                                                                   Margin="0,2,0,0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding At, Converter={StaticResource DateToRelative}}"
                                                               Style="{StaticResource CaptionTextStyle}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding HasRecentActivities, Converter={StaticResource InverseBoolToVisibility}}">
                                    <Border Background="{StaticResource TealSoftBrush}"
                                            Width="64" Height="64"
                                            CornerRadius="32"
                                            HorizontalAlignment="Center">
                                        <Path Data="{StaticResource IconReports}"
                                              Stroke="{StaticResource TealPressedBrush}"
                                              StrokeThickness="1.7"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Width="28" Height="28" />
                                    </Border>
                                    <TextBlock Text="لا توجد أنشطة حديثة"
                                               Style="{StaticResource SubheadTextStyle}"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="ستظهر هنا أحدث التسجيلات والمدفوعات"
                                               Style="{StaticResource CaptionTextStyle}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <controls:LoadingOverlay IsBusy="{Binding IsLoading}"
                                 Message="جاري تحميل لوحة التحكم…" />
    </Grid>
</UserControl>
