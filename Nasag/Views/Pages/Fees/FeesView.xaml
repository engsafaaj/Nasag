<UserControl x:Class="Nasag.Views.Pages.Fees.FeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Fees"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:FeesViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <helpers:InstallmentStatusToBackgroundConverter x:Key="InstallmentStatusToBackground" />
        <helpers:InstallmentStatusToForegroundConverter x:Key="InstallmentStatusToForeground" />
        <helpers:InstallmentNotPaidToVisibilityConverter x:Key="InstallmentNotPaidToVisibility" />
        <helpers:FirstItemConverter x:Key="FirstItem" />

        <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="MinHeight" Value="78" />
        </Style>

        <Style x:Key="SectionCardHeader" TargetType="Border">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding RecordPaymentCommand}" />
        <KeyBinding Modifiers="Control" Key="P" Command="{Binding PrintStatementCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Page header -->
        <Grid Grid.Row="0" Margin="0,0,0,12" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource IconButton}"
                    Command="{Binding ReloadCommand}"
                    VerticalAlignment="Center"
                    ToolTip="تحديث البيانات (F5)">
                <Path Data="{StaticResource IconRefresh}"
                      Stroke="{StaticResource TextPrimaryBrush}"
                      StrokeThickness="1.7"
                      Fill="Transparent"
                      Stretch="Uniform"
                      Width="16" Height="16" />
            </Button>

            <StackPanel Grid.Column="2"
                        FlowDirection="RightToLeft"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleAr}"
                           Style="{StaticResource SectionTitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding SubtitleAr}"
                           Style="{StaticResource SectionSubtitle}"
                           TextAlignment="Right"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <!-- Row 1: Selector toolbar -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="14,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" MinWidth="220" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="الصف"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding Grades}"
                                                 SelectedItem="{Binding SelectedGrade, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الصف" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="الشعبة"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding AvailableSections}"
                                                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                                                 DisplayMemberPath="DisplayName"
                                                 Placeholder="الشعبة" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                    <TextBlock Text="الطالب"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <controls:SearchableComboBox ItemsSource="{Binding AvailableStudents}"
                                                 SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                                                 DisplayMemberPath="DisplayName"
                                                 Placeholder="اختر الطالب" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="8,0,0,0">
                    <TextBlock Text="بحث برقم الطالب"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="QuickStudentNumberBox"
                                 Grid.Column="0"
                                 Text="{Binding QuickStudentNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="34"
                                 Padding="10,4"
                                 VerticalContentAlignment="Center"
                                 ToolTip="اكتب رقم الطالب ثم اضغط Enter">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding QuickLocateCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Style="{StaticResource IconButton}"
                                Command="{Binding QuickLocateCommand}"
                                Margin="6,0,0,0"
                                ToolTip="بحث">
                            <Path Data="{StaticResource IconSearch}"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.7"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Student summary strip -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorder}"
                Padding="18,14"
                Margin="0,0,0,12"
                Visibility="{Binding HasStudentSelected, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="44" Height="44"
                        CornerRadius="22"
                        Background="{StaticResource TealSoftBrush}"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding InitialLetter}"
                               Foreground="{StaticResource TealPressedBrush}"
                               FontWeight="Bold"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding StudentFullName}"
                                   FontSize="{StaticResource FontSizeLg}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <Border Style="{StaticResource TealPill}"
                                CornerRadius="999"
                                Padding="8,2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasFeePlan, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding FeePlanName}"
                                       Style="{StaticResource TealPillText}" />
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="{Binding GradeName}" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text=" - " Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="{Binding SectionName}" Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <TextBlock Text="الرقم"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeXs}"
                               TextAlignment="Left" />
                    <TextBlock Text="{Binding StudentNumberDisplay}"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextAlignment="Left"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 3: Empty-state CTA — no FeePlan yet -->
        <Border Grid.Row="3"
                Style="{StaticResource CardBorder}"
                Padding="22,20"
                Margin="0,0,0,12"
                Visibility="{Binding ShowEmptyStateCta, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="48" Height="48" CornerRadius="24"
                        Background="{StaticResource WarningSoftBrush}"
                        VerticalAlignment="Center">
                    <Path Data="{StaticResource IconFees}"
                          Stroke="{StaticResource WarningBrush}"
                          StrokeThickness="2"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="22" Height="22" />
                </Border>
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="لا توجد خطة رسوم لهذا الطالب في السنة الحالية"
                               FontWeight="Bold"
                               FontSize="{StaticResource FontSizeLg}"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="قم بتعيين خطة رسوم مناسبة لصف الطالب لتفعيل تسجيل الدفعات."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="2"
                        Style="{StaticResource BubbleButton}"
                        Command="{Binding AssignFeePlanCommand}"
                        Padding="16,8"
                        Content="تعيين خطة رسوم"
                        VerticalAlignment="Center"
                        Visibility="{Binding CanManageFees, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Border>

        <!-- Row 4: 3 stat cards. RTL visual order (right -> left): Total, Paid, Remaining -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding HasStudentSelected}" Value="True" />
                                <Condition Binding="{Binding HasFeePlan}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Column 0 (visually right in RTL): Total -->
            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="إجمالي الرسوم"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding TotalAmountText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- Column 2 (visually middle): Paid -->
            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="إجمالي المدفوع"
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="{StaticResource FontSizeSm}"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1"
                                Style="{StaticResource SuccessPill}"
                                CornerRadius="999"
                                Padding="8,2"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding PaidPercentText}"
                                       Style="{StaticResource SuccessPillText}"
                                       FontSize="{StaticResource FontSizeXs}" />
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding PaidAmountText}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- Column 4 (visually left): Remaining -->
            <Border Grid.Column="4" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="المتبقي"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="{StaticResource FontSizeSm}" />
                    <TextBlock Text="{Binding RemainingAmountText}"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 5: Two side-by-side cards -->
        <Grid Grid.Row="5"
              Visibility="{Binding HasFeePlan, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Installments card (right column in RTL) -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardBorder}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SectionCardHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="تفاصيل الأقساط"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       VerticalAlignment="Center" />

                            <Border Grid.Column="1"
                                    Background="{StaticResource TealSoftBrush}"
                                    CornerRadius="10"
                                    Padding="10,3"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding InstallmentsCountText}"
                                           Foreground="{StaticResource TealPressedBrush}"
                                           FontWeight="Bold"
                                           FontSize="{StaticResource FontSizeSm}" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <DataGrid ItemsSource="{Binding Installments}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#"
                                                    Binding="{Binding Number}"
                                                    Width="70" />
                                <DataGridTextColumn Header="تاريخ الاستحقاق"
                                                    Binding="{Binding DueDateText}"
                                                    Width="150" />
                                <DataGridTextColumn Header="المبلغ"
                                                    Binding="{Binding AmountText}"
                                                    Width="110" />
                                <DataGridTextColumn Header="المدفوع"
                                                    Binding="{Binding PaidAmountText}"
                                                    Width="110" />

                                <DataGridTemplateColumn Header="الحالة" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Status, Converter={StaticResource InstallmentStatusToBackground}}"
                                                    CornerRadius="10"
                                                    Padding="10,4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusLabelAr}"
                                                           Foreground="{Binding Status, Converter={StaticResource InstallmentStatusToForeground}}"
                                                           FontWeight="SemiBold"
                                                           FontSize="{StaticResource FontSizeSm}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="ملاحظات"
                                                    Binding="{Binding LastPaymentDateText}"
                                                    Width="*" />

                                <DataGridTemplateColumn Header="إجراءات" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- Outer wrapper hides the action when the current user lacks permission.
                                                 Inner Button hides itself for installments that are already paid. -->
                                            <ContentControl HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding DataContext.CanManageFees, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}">
                                                <Button Style="{StaticResource RowActionButton}"
                                                        Command="{Binding DataContext.RecordPaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}"
                                                        Visibility="{Binding Status, Converter={StaticResource InstallmentNotPaidToVisibility}}"
                                                        ToolTip="تسجيل دفعة لهذا القسط">
                                                    <Path Data="{StaticResource IconAdd}"
                                                          Stroke="{StaticResource TealPressedBrush}"
                                                          StrokeThickness="1.8"
                                                          Fill="Transparent"
                                                          Stretch="Uniform"
                                                          Width="14" Height="14" />
                                                </Button>
                                            </ContentControl>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state for installments -->
                        <Border Background="{StaticResource OverlayBrush}"
                                Visibility="{Binding HasInstallments, Converter={StaticResource InverseBoolToVisibility}}"
                                IsHitTestVisible="True">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,30">
                                <Border Background="{StaticResource TealSoftBrush}"
                                        Width="64" Height="64"
                                        CornerRadius="32"
                                        HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconFees}"
                                          Stroke="{StaticResource TealPressedBrush}"
                                          StrokeThickness="1.7"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="28" Height="28" />
                                </Border>
                                <TextBlock Text="لا توجد أقساط مسجلة"
                                           Style="{StaticResource SubheadTextStyle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0" />
                                <TextBlock Text="قم بتعيين خطة رسوم ليتم توليد أقساط الطالب تلقائياً"
                                           Style="{StaticResource CaptionTextStyle}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,4,0,12" />
                                <Button Style="{StaticResource BubbleButton}"
                                        Command="{Binding AssignFeePlanCommand}"
                                        Padding="16,8"
                                        Content="تعيين خطة رسوم"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding CanManageFees, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Payments card (left column visually left) -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardBorder}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource SectionCardHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="سجل الدفعات"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       VerticalAlignment="Center" />

                            <Border Grid.Column="1"
                                    Background="{StaticResource InfoSoftBrush}"
                                    CornerRadius="10"
                                    Padding="10,3"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding PaymentsCountText}"
                                           Foreground="{StaticResource InfoBrush}"
                                           FontWeight="Bold"
                                           FontSize="{StaticResource FontSizeSm}" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <DataGrid ItemsSource="{Binding Payments}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#"
                                                    Binding="{Binding ReceiptNumber}"
                                                    Width="70" />
                                <DataGridTextColumn Header="التاريخ"
                                                    Binding="{Binding PaymentDateText}"
                                                    Width="150" />
                                <DataGridTextColumn Header="المبلغ"
                                                    Binding="{Binding AmountText}"
                                                    Width="110" />
                                <DataGridTextColumn Header="الطريقة"
                                                    Binding="{Binding MethodLabelAr}"
                                                    Width="100" />
                                <DataGridTextColumn Header="القسط"
                                                    Binding="{Binding InstallmentLabel}"
                                                    Width="80" />
                                <DataGridTextColumn Header="ملاحظات"
                                                    Binding="{Binding Notes}"
                                                    Width="*" />

                                <DataGridTemplateColumn Header="إجراءات" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        FlowDirection="RightToLeft"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource RowActionButton}"
                                                        Command="{Binding DataContext.PrintReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="طباعة سند">
                                                    <Path Data="{StaticResource IconPrint}"
                                                          Stroke="{StaticResource InfoBrush}"
                                                          StrokeThickness="1.6"
                                                          Fill="Transparent"
                                                          Stretch="Uniform"
                                                          Width="14" Height="14" />
                                                </Button>
                                                <Button Style="{StaticResource RowActionButton}"
                                                        Command="{Binding DataContext.DeletePaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="6,0,0,0"
                                                        Visibility="{Binding DataContext.CanManageFees, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}"
                                                        ToolTip="حذف الدفعة">
                                                    <Path Data="{StaticResource IconDelete}"
                                                          Stroke="{StaticResource DangerBrush}"
                                                          StrokeThickness="1.7"
                                                          Fill="Transparent"
                                                          Stretch="Uniform"
                                                          Width="14" Height="14" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty state for payments -->
                        <Border Background="{StaticResource OverlayBrush}"
                                Visibility="{Binding HasPayments, Converter={StaticResource InverseBoolToVisibility}}"
                                IsHitTestVisible="True">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,30">
                                <Border Background="{StaticResource TealSoftBrush}"
                                        Width="64" Height="64"
                                        CornerRadius="32"
                                        HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconFees}"
                                          Stroke="{StaticResource TealPressedBrush}"
                                          StrokeThickness="1.7"
                                          Fill="Transparent"
                                          Stretch="Uniform"
                                          Width="28" Height="28" />
                                </Border>
                                <TextBlock Text="لا توجد دفعات بعد"
                                           Style="{StaticResource SubheadTextStyle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0" />
                                <TextBlock Text="ابدأ بتسجيل أول دفعة لهذا الطالب لظهور سند القبض هنا"
                                           Style="{StaticResource CaptionTextStyle}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,4,0,12" />
                                <Button Style="{StaticResource BubbleButton}"
                                        Command="{Binding RecordPaymentCommand}"
                                        Padding="16,8"
                                        Content="تسجيل دفعة"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding CanManageFees, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 6: Sticky action bar -->
        <Border Grid.Row="6"
                Style="{StaticResource CardBorder}"
                Padding="16"
                Margin="0,12,0,0"
                Visibility="{Binding HasFeePlan, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left (visually): total remaining (in RTL Column=0 sits at the right; the design
                     places the remaining label on the visual LEFT, so we use Column 1 for the label
                     and Column 0 for the actions to mirror the screenshot properly within RTL.
                     The reference image actually shows the remaining label on the LEFT and the
                     three buttons on the RIGHT — which is exactly what putting the actions in
                     Column 0 and the label in Column 1 (HorizontalAlignment Left) produces under RTL. -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            FlowDirection="LeftToRight">
                    <TextBlock Text="إجمالي المتبقي: "
                               FontFamily="{StaticResource TajawalFont}"
                               FontSize="{StaticResource FontSizeLg}"
                               FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding RemainingAmountText}"
                               FontFamily="{StaticResource TajawalFont}"
                               FontSize="{StaticResource FontSizeLg}"
                               FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding PrintStatementCommand}"
                            Padding="14,8"
                            ToolTip="طباعة كشف حساب (Ctrl+P)">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <Path Data="{StaticResource IconPrint}"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.6"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="كشف حساب"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding PrintReceiptCommand}"
                            CommandParameter="{Binding Payments, Converter={StaticResource FirstItem}}"
                            Margin="10,0,0,0"
                            Padding="14,8"
                            Visibility="{Binding CanManageFees, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="طباعة آخر سند قبض">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <Path Data="{StaticResource IconPrint}"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.6"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="طباعة آخر سند"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BubbleButton}"
                            Command="{Binding RecordPaymentCommand}"
                            Margin="10,0,0,0"
                            Padding="18,8"
                            Visibility="{Binding CanManageFees, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="تسجيل دفعة (Ctrl+N)">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                            <Path Data="{StaticResource IconAdd}"
                                  Stroke="White"
                                  StrokeThickness="1.9"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="تسجيل دفعة"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <controls:LoadingOverlay Grid.RowSpan="7"
                                 IsBusy="{Binding IsLoading}"
                                 Message="جاري التحميل…" />
    </Grid>
</UserControl>
