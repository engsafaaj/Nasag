<Window x:Class="Nasag.Views.Pages.Fees.Dialogs.AssignFeePlanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Nasag.Controls"
        mc:Ignorable="d"
        Style="{StaticResource BaseWindowStyle}"
        Title="تعيين خطة رسوم"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header (drag region) -->
            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Padding="22,18,22,8"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="48" Height="48"
                                CornerRadius="24"
                                Background="{StaticResource TealSoftBrush}"
                                VerticalAlignment="Center">
                            <Path Data="{StaticResource IconFees}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="22" Height="22" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="تعيين خطة رسوم"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="StudentSummaryText"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Click="OnCancelClick"
                            ToolTip="إغلاق"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="22,4,22,18">
                <Grid>
                    <!-- Case A: plans available -->
                    <StackPanel x:Name="PlansAvailablePanel">
                        <TextBlock Text="خطة الرسوم" Style="{StaticResource FieldLabel}" />
                        <controls:SearchableComboBox x:Name="PlanBox"
                                                     DisplayMemberPath="Display"
                                                     Placeholder="اختر خطة الرسوم"
                                                     MinHeight="36" />

                        <Border Background="{StaticResource TealSoftBrush}"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="إجمالي الخطة: "
                                               Foreground="{StaticResource TealPressedBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSizeSm}" />
                                    <TextBlock x:Name="PlanTotalText"
                                               Foreground="{StaticResource TealPressedBrush}"
                                               FontWeight="Bold"
                                               FontSize="{StaticResource FontSizeSm}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="عدد الأقساط: "
                                               Foreground="{StaticResource TealPressedBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSizeSm}" />
                                    <TextBlock x:Name="PlanInstallmentsText"
                                               Foreground="{StaticResource TealPressedBrush}"
                                               FontWeight="Bold"
                                               FontSize="{StaticResource FontSizeSm}" />
                                </StackPanel>
                                <TextBlock x:Name="PlanSummaryText"
                                           Text="ستُولَّد الأقساط بمقدار متساوٍ على فترة السنة الدراسية."
                                           Style="{StaticResource MutedTextStyle}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Error banner (Danger soft) -->
                        <Border x:Name="ErrorBanner"
                                Background="{StaticResource DangerSoftBrush}"
                                BorderBrush="{StaticResource DangerBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,6"
                                Margin="0,10,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="ErrorText"
                                       Foreground="{StaticResource DangerBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <!-- Case B: no plans -->
                    <Border x:Name="NoPlansPanel"
                            Background="{StaticResource WarningSoftBrush}"
                            CornerRadius="10"
                            Padding="14"
                            Visibility="Collapsed">
                        <TextBlock Text="لا توجد خطط رسوم معرَّفة لهذا الصف. تواصل مع مدير المدرسة لإنشاء خطة."
                                   Foreground="{StaticResource WarningBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeSm}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource SecondaryButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Click="OnCancelClick"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button x:Name="ConfirmButton"
                            Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Click="OnConfirmClick"
                            Content="تعيين"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
