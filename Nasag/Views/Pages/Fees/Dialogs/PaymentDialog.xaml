<Window x:Class="Nasag.Views.Pages.Fees.Dialogs.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Nasag.Controls"
        mc:Ignorable="d"
        Style="{StaticResource BaseWindowStyle}"
        Title="تسجيل دفعة جديدة"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="RightToLeft">

    <Border CornerRadius="14"
            Background="{StaticResource CardSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#1B3A57" BlurRadius="36" ShadowDepth="0" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header (drag region) -->
            <Border Grid.Row="0"
                    x:Name="HeaderBar"
                    Padding="22,18,22,8"
                    Background="Transparent"
                    MouseLeftButtonDown="OnHeaderDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44"
                                CornerRadius="22"
                                Background="{StaticResource TealSoftBrush}"
                                VerticalAlignment="Center">
                            <Path Data="{StaticResource IconFees}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="22" Height="22" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="تسجيل دفعة"
                                       FontFamily="{StaticResource TajawalFont}"
                                       FontSize="{StaticResource FontSizeLg}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="StudentSummaryText"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Click="OnCancelClick"
                            ToolTip="إغلاق"
                            VerticalAlignment="Top">
                        <TextBlock Text="✕"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Padding="22,4,22,18">
                <StackPanel>

                    <Border Background="{StaticResource InfoSoftBrush}"
                            CornerRadius="10"
                            Padding="12,8"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock x:Name="RemainingSummaryText"
                                       Foreground="{StaticResource InfoBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeSm}" />
                            <TextBlock x:Name="InstallmentRemainingText"
                                       Style="{StaticResource MutedTextStyle}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Margin="0,4,0,0"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="المبلغ" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="AmountBox"
                             MaxLength="16"
                             LostFocus="OnAmountLostFocus"
                             GotFocus="OnAmountGotFocus"
                             Margin="0,0,0,12" />

                    <TextBlock Text="طريقة الدفع" Style="{StaticResource FieldLabel}" />
                    <controls:SearchableComboBox x:Name="MethodBox"
                                                 DisplayMemberPath="DisplayName"
                                                 Placeholder="اختر طريقة الدفع"
                                                 MinHeight="36"
                                                 Margin="0,0,0,12" />

                    <TextBlock Text="تاريخ الدفع" Style="{StaticResource FieldLabel}" />
                    <DatePicker x:Name="DateBox"
                                Margin="0,0,0,12" />

                    <TextBlock Text="القسط المرتبط" Style="{StaticResource FieldLabel}" />
                    <controls:SearchableComboBox x:Name="InstallmentBox"
                                                 DisplayMemberPath="Display"
                                                 Placeholder="بدون قسط محدد"
                                                 MinHeight="36"
                                                 Margin="0,0,0,12" />

                    <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="NotesBox"
                             MaxLength="300"
                             Height="70"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,4" />

                    <!-- Error banner (Danger soft) -->
                    <Border x:Name="ErrorBanner"
                            Background="{StaticResource DangerSoftBrush}"
                            BorderBrush="{StaticResource DangerBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,6"
                            Margin="0,10,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorText"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="0,0,14,14"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Style="{StaticResource SecondaryButton}"
                            Padding="22,8"
                            Margin="0,0,10,0"
                            Click="OnCancelClick"
                            Content="إلغاء"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Padding="26,8"
                            Click="OnConfirmClick"
                            Content="حفظ"
                            IsDefault="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
