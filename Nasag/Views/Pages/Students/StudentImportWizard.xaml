<Window x:Class="Nasag.Views.Pages.Students.StudentImportWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Students"
        xmlns:helpers="clr-namespace:Nasag.Helpers"
        xmlns:controls="clr-namespace:Nasag.Controls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:StudentImportWizardViewModel}"
        Style="{StaticResource BaseWindowStyle}"
        Title="معالج استيراد الطلاب"
        Width="900" Height="640"
        MinWidth="760" MinHeight="540"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ===== Header ===== -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Right">
                    <TextBlock Text="معالج استيراد الطلاب"
                               Style="{StaticResource SectionTitle}"
                               TextAlignment="Right" />
                    <TextBlock Text="استورد بيانات الطلاب من ملف Excel بسهولة. اتّبع الخطوات بالترتيب."
                               Style="{StaticResource SectionSubtitle}"
                               TextAlignment="Right" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding DownloadTemplateCommand}"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconExport}"
                              Stroke="{StaticResource TealPressedBrush}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14"
                              VerticalAlignment="Center" />
                        <TextBlock Text="تنزيل قالب فارغ"
                                   Foreground="{StaticResource TealPressedBrush}"
                                   FontWeight="Medium"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== Stepper ===== -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="18,14" Margin="0,0,0,12">
                <UniformGrid Columns="4" Rows="1">
                    <UniformGrid.Resources>
                        <Style x:Key="StepDot" TargetType="Border">
                            <Setter Property="Width" Value="28" />
                            <Setter Property="Height" Value="28" />
                            <Setter Property="CornerRadius" Value="14" />
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                        <Style x:Key="StepText" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                            <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
                            <Setter Property="FontWeight" Value="Medium" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Margin" Value="8,0,0,0" />
                        </Style>
                    </UniformGrid.Resources>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepDot}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStepPickFile}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TealPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="1" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="اختر الملف" Style="{StaticResource StepText}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepDot}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStepPreview}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TealPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="2" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="مراجعة البيانات" Style="{StaticResource StepText}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepDot}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStepConfirm}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource TealPrimaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="3" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="اختر طريقة الاستيراد" Style="{StaticResource StepText}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StepDot}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStepResult}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="4" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="النتيجة" Style="{StaticResource StepText}" />
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- ===== Body ===== -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="20">
                <Grid>
                    <!-- Step 1: Pick file -->
                    <StackPanel Visibility="{Binding IsStepPickFile, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Border Width="84" Height="84" CornerRadius="42"
                                Background="{StaticResource TealSoftBrush}"
                                HorizontalAlignment="Center">
                            <Path Data="{StaticResource IconImport}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="1.8"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="40" Height="40" />
                        </Border>
                        <TextBlock Text="اختر ملف Excel لاستيراد بيانات الطلاب"
                                   Style="{StaticResource SubheadTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,4" />
                        <TextBlock Text="يجب أن يحتوي الملف على أعمدة عربية مطابقة لقالب الاستيراد."
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="{StaticResource FontSizeSm}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,18" />
                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding PickFileCommand}"
                                HorizontalAlignment="Center"
                                Padding="26,10">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconImport}"
                                      Stroke="White"
                                      StrokeThickness="1.8"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Width="14" Height="14"
                                      VerticalAlignment="Center" />
                                <TextBlock Text="اختر ملف…"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Step 2: Preview -->
                    <Grid Visibility="{Binding IsStepPreview, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Style="{StaticResource SubheadTextStyle}">
                                <Run Text="إجمالي الصفوف: " />
                                <Run Text="{Binding TotalRows, Mode=OneWay}" FontWeight="Bold" />
                                <Run Text="   •   صحيحة: " />
                                <Run Text="{Binding ValidRows, Mode=OneWay}"
                                     FontWeight="Bold"
                                     Foreground="{StaticResource SuccessBrush}" />
                                <Run Text="   •   بها أخطاء: " />
                                <Run Text="{Binding InvalidRows, Mode=OneWay}"
                                     FontWeight="Bold"
                                     Foreground="{StaticResource DangerBrush}" />
                            </TextBlock>
                            <TextBlock Text="{Binding FilePath}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="60" />
                                <DataGridTextColumn Header="رقم الطالب" Binding="{Binding StudentNumber}" Width="110" />
                                <DataGridTextColumn Header="الاسم" Binding="{Binding FullName}" Width="*" />
                                <DataGridTextColumn Header="الجنس" Binding="{Binding Gender}" Width="80" />
                                <DataGridTextColumn Header="الصف" Binding="{Binding GradeName}" Width="120" />
                                <DataGridTextColumn Header="الشعبة" Binding="{Binding SectionName}" Width="100" />
                                <DataGridTextColumn Header="ولي الأمر" Binding="{Binding GuardianFullName}" Width="160" />
                                <DataGridTemplateColumn Header="الحالة" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="999"
                                                    Padding="10,3"
                                                    HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                            <Setter Property="Text" Value="جاهز" />
                                                            <Setter Property="FontWeight" Value="Medium" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                    <Setter Property="Text" Value="{Binding ErrorMessage}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Step 3: Confirm + mode -->
                    <StackPanel Visibility="{Binding IsStepConfirm, Converter={StaticResource BoolToVisibility}}"
                                MaxWidth="640"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="اختر طريقة الاستيراد"
                                   Style="{StaticResource SubheadTextStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                   FontSize="{StaticResource FontSizeSm}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,4,0,18">
                            <Run Text="سيتم استيراد " />
                            <Run Text="{Binding ValidRows, Mode=OneWay}" FontWeight="Bold" />
                            <Run Text=" طالب جاهز." />
                        </TextBlock>

                        <RadioButton GroupName="ImportMode"
                                     IsChecked="{Binding ModeIsAppend, Mode=TwoWay}"
                                     Margin="0,0,0,10">
                            <Border Style="{StaticResource CardBorder}" Padding="14" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="إضافة إلى الطلاب الحاليين"
                                               FontWeight="Bold"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="يُحتفظ بكل البيانات الموجودة، وتُضاف الصفوف الجديدة فقط."
                                               Style="{StaticResource MutedTextStyle}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </RadioButton>

                        <RadioButton GroupName="ImportMode"
                                     IsChecked="{Binding ModeIsReplace, Mode=TwoWay}">
                            <Border Style="{StaticResource CardBorder}" Padding="14" Margin="6,0,0,0"
                                    BorderBrush="{StaticResource DangerBrush}"
                                    BorderThickness="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="حذف الحاليين ثم الاستيراد"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource DangerBrush}"
                                               Style="{StaticResource BodyTextStyle}" />
                                    <TextBlock Text="سيتم حذف جميع الطلاب وولي الأمور والسجلات المرتبطة قبل الاستيراد. لا يمكن التراجع."
                                               Style="{StaticResource MutedTextStyle}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </RadioButton>
                    </StackPanel>

                    <!-- Step 4: Result -->
                    <StackPanel Visibility="{Binding IsStepResult, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Border Width="84" Height="84" CornerRadius="42" HorizontalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Success}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Path StrokeThickness="2.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="36" Height="36">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="M5 12 L10 17 L20 7" />
                                        <Setter Property="Stroke" Value="{StaticResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Success}" Value="False">
                                                <Setter Property="Data" Value="M6 6 L18 18 M18 6 L6 18" />
                                                <Setter Property="Stroke" Value="{StaticResource DangerBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Border>
                        <TextBlock HorizontalAlignment="Center"
                                   Margin="0,14,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SubheadTextStyle}">
                                    <Setter Property="Text" Value="تم الاستيراد بنجاح" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Success}" Value="False">
                                            <Setter Property="Text" Value="فشل الاستيراد" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource MutedTextStyle}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="500" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== Footer ===== -->
            <Border Grid.Row="3"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,14,0,0"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource GhostButton}"
                            Content="إغلاق"
                            Click="OnCloseClick" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- Preview → Pick file -->
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="رجوع"
                                Command="{Binding BackToPickFileCommand}"
                                Visibility="{Binding IsStepPreview, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0" />
                        <!-- Confirm → Preview -->
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="رجوع"
                                Command="{Binding BackToPreviewCommand}"
                                Visibility="{Binding IsStepConfirm, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,0,8,0" />

                        <!-- Next from Preview -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="التالي"
                                Command="{Binding GoToConfirmCommand}"
                                Visibility="{Binding IsStepPreview, Converter={StaticResource BoolToVisibility}}" />
                        <!-- Run import -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="بدء الاستيراد"
                                Command="{Binding RunImportCommand}"
                                Visibility="{Binding IsStepConfirm, Converter={StaticResource BoolToVisibility}}" />
                        <!-- Result done -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="انتهيت"
                                Click="OnDoneClick"
                                Visibility="{Binding IsStepResult, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <controls:LoadingOverlay IsBusy="{Binding IsBusy}" Message="{Binding BusyMessage}" />
    </Grid>
</Window>
