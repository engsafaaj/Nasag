<UserControl x:Class="Nasag.Views.Pages.Students.StudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Students"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             xmlns:views="clr-namespace:Nasag.Views.Pages.Students"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:StudentsViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <helpers:StudentStatusToArabicConverter x:Key="StatusToText" />
        <helpers:StudentStatusToBackgroundConverter x:Key="StatusBg" />
        <helpers:StudentStatusToForegroundConverter x:Key="StatusFg" />
        <helpers:StudentStatusEqualsConverter x:Key="StatusEquals" />
        <helpers:GenderToArabicConverter x:Key="GenderToText" />
        <helpers:InitialLetterConverter x:Key="InitialLetter" />
    </UserControl.Resources>

    <!--
        System-wide keyboard shortcuts:
        - Ctrl+N : add a new student
        - Ctrl+F : focus the search box (handled in code-behind)
        - F5     : reload
        - Delete : delete the currently selected row
    -->
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding AddStudentCommand}" />
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <!-- ==================== List Mode ==================== -->
        <Grid Visibility="{Binding ShowList, Converter={StaticResource BoolToVisibility}}"
              Margin="22,18,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--
                ===== Header =====
                Wrapped in FlowDirection=LeftToRight so column 1 is the *actual*
                right edge regardless of any inherited RTL mirroring. The title
                StackPanel re-enters RTL internally for correct Arabic shaping.
            -->
            <Grid Grid.Row="0" Margin="0,0,0,14" FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1"
                            FlowDirection="RightToLeft"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleAr}"
                               Style="{StaticResource SectionTitle}"
                               TextAlignment="Right"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding SubtitleAr}"
                               Style="{StaticResource SectionSubtitle}"
                               TextAlignment="Right"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>

            <!--
                ===== Toolbar (no Add button — that's the FAB at bottom-right) =====

                Column index → visual position (RTL: column 0 is on the visual right).
                  0  Grade filter      (visually rightmost)
                  1  Section filter
                  2  Status filter
                  3  Page-size picker
                  4  Search box (grows)
                  5  Refresh
                  6  Clear filters     (different icon than refresh)
                  7  Export
                  8  Import            (visually leftmost)
            -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Padding="14,10"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <controls:SearchableComboBox Grid.Column="0"
                                                 ItemsSource="{Binding Grades}"
                                                 SelectedItem="{Binding SelectedGrade, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الصف"
                                                 MinWidth="150" />

                    <controls:SearchableComboBox Grid.Column="1"
                                                 ItemsSource="{Binding AvailableSections}"
                                                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                                                 DisplayMemberPath="NameAr"
                                                 Placeholder="الشعبة"
                                                 MinWidth="130"
                                                 Margin="8,0,0,0" />

                    <controls:SearchableComboBox Grid.Column="2"
                                                 ItemsSource="{Binding StatusOptions}"
                                                 SelectedItem="{Binding SelectedStatus, Mode=TwoWay}"
                                                 DisplayMemberPath="Label"
                                                 Placeholder="الحالة"
                                                 MinWidth="140"
                                                 Margin="8,0,0,0" />

                    <controls:SearchableComboBox Grid.Column="3"
                                                 ItemsSource="{Binding PageSizeOptions}"
                                                 SelectedItem="{Binding PageSize, Mode=TwoWay}"
                                                 Placeholder="الصفحة"
                                                 MinWidth="86"
                                                 Margin="8,0,0,0" />

                    <Border Grid.Column="4"
                            Background="{StaticResource BackgroundBrush}"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="10,2"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            MinWidth="180"
                            MaxWidth="380"
                            Margin="8,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0"
                                  Data="{StaticResource IconSearch}"
                                  Stroke="{StaticResource TextMutedBrush}"
                                  StrokeThickness="1.6"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="16" Height="16"
                                  VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MinHeight="30"
                                     VerticalContentAlignment="Center"
                                     Margin="8,0,0,0"
                                     ToolTip="بحث بالاسم أو الرقم أو الجوال (Ctrl+F)" />
                        </Grid>
                    </Border>

                    <Button Grid.Column="5"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ReloadCommand}"
                            Margin="8,0,0,0"
                            Padding="10,6"
                            ToolTip="تحديث البيانات (F5)">
                        <Path Data="{StaticResource IconRefresh}"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14" />
                    </Button>

                    <Button Grid.Column="6"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ClearFiltersCommand}"
                            Margin="6,0,0,0"
                            Padding="10,6"
                            ToolTip="مسح كل الفلاتر">
                        <Path Data="{StaticResource IconFilterClear}"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14" />
                    </Button>

                    <Button Grid.Column="7"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportExcelCommand}"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            ToolTip="تصدير إلى Excel">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconExport}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="1.6"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="تصدير"
                                       Foreground="{StaticResource TealPressedBrush}"
                                       FontWeight="Medium"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="8"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ImportExcelCommand}"
                            Margin="6,0,0,0"
                            Padding="12,6"
                            ToolTip="استيراد من Excel">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconImport}"
                                  Stroke="{StaticResource InfoBrush}"
                                  StrokeThickness="1.6"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="استيراد"
                                       Foreground="{StaticResource InfoBrush}"
                                       FontWeight="Medium"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ===== DataGrid card ===== -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              x:Name="StudentsGrid"
                              ItemsSource="{Binding Students}"
                              SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                              Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}"
                              MouseDoubleClick="OnRowDoubleClick"
                              IsReadOnly="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الطالب"
                                                Binding="{Binding StudentNumber}"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="Medium" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="الاسم" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="6,4">
                                            <Border Width="30" Height="30"
                                                    CornerRadius="15"
                                                    Background="{StaticResource TealSoftBrush}">
                                                <TextBlock Text="{Binding FullName, Converter={StaticResource InitialLetter}}"
                                                           Foreground="{StaticResource TealPressedBrush}"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="{Binding FullName}"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="الصف"
                                                Binding="{Binding GradeName}"
                                                Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="الشعبة"
                                                Binding="{Binding SectionName}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="الحالة" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="999"
                                                Padding="10,3"
                                                Margin="6,4"
                                                HorizontalAlignment="Center"
                                                Background="{Binding Status, Converter={StaticResource StatusBg}}">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusFg}}"
                                                       FontSize="{StaticResource FontSizeSm}"
                                                       FontWeight="Medium" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="الجوال"
                                                Binding="{Binding Phone}"
                                                Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="ولي الأمر"
                                                Binding="{Binding GuardianName}"
                                                Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="إجراءات" Width="240" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="6,2">
                                            <Button Style="{StaticResource RowActionButton}"
                                                    ToolTip="تعديل"
                                                    Command="{Binding DataContext.EditStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconEdit}"
                                                      Stroke="{StaticResource TextSecondaryBrush}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                            <Button Style="{StaticResource RowActionButton}"
                                                    Margin="6,0,0,0"
                                                    ToolTip="نقل إلى شعبة أخرى"
                                                    Command="{Binding DataContext.MoveStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="M3 12 H21 M15 6 L21 12 L15 18"
                                                      Stroke="{StaticResource InfoBrush}"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                            <Button Style="{StaticResource RowActionButton}"
                                                    ToolTip="أرشفة"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding DataContext.ArchiveStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconBackup}"
                                                      Stroke="{StaticResource WarningBrush}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                            <Button ToolTip="استعادة"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding DataContext.RestoreStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource RowActionButton}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status, Converter={StaticResource StatusEquals}, ConverterParameter=Archived}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Path Data="{StaticResource IconRefresh}"
                                                      Stroke="{StaticResource SuccessBrush}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                            <Button Style="{StaticResource RowActionButton}"
                                                    ToolTip="حذف نهائي"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding DataContext.DeleteStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconDelete}"
                                                      Stroke="{StaticResource DangerBrush}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="0"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,40">
                        <Border Background="{StaticResource TealSoftBrush}"
                                Width="64" Height="64"
                                CornerRadius="32"
                                HorizontalAlignment="Center">
                            <Path Data="{StaticResource IconStudents}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="1.7"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="28" Height="28" />
                        </Border>
                        <TextBlock Text="لا توجد نتائج مطابقة"
                                   Style="{StaticResource SubheadTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="جرّب تعديل الفلاتر أو إضافة طالب جديد"
                                   Style="{StaticResource CaptionTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Pagination footer -->
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderStrongBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="14,10"
                            Background="{StaticResource CardSurfaceBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PaginationLabel}"
                                       Style="{StaticResource MutedTextStyle}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding PrevPageCommand}"
                                        Margin="0,0,8,0"
                                        Padding="14,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconChevronRight}"
                                              Stroke="{StaticResource TextPrimaryBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Width="12" Height="12"
                                              VerticalAlignment="Center" />
                                        <TextBlock Text="السابق"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <ComboBox x:Name="PageJumpBox"
                                          ItemsSource="{Binding PageNumbers}"
                                          SelectedItem="{Binding Page, Mode=OneWay}"
                                          IsEditable="True"
                                          MinWidth="120"
                                          Padding="10,4"
                                          VerticalContentAlignment="Center"
                                          ToolTip="انتقل إلى صفحة معينة"
                                          KeyDown="OnPageJumpKeyDown"
                                          SelectionChanged="OnPageJumpSelectionChanged"
                                          Margin="0,0,8,0" />

                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding NextPageCommand}"
                                        Padding="14,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="التالي"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                        <Path Data="{StaticResource IconChevronLeft}"
                                              Stroke="{StaticResource TextPrimaryBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Width="12" Height="12"
                                              VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== Editor Mode ==================== -->
        <Grid Visibility="{Binding ShowEditor, Converter={StaticResource BoolToVisibility}}">
            <views:StudentEditorView DataContext="{Binding Editor}" />
        </Grid>

        <!--
            ===== Floating Action Button (Add Student) =====
            Overlay on top of all page content, anchored to the bottom-right of
            the page. Wrapped in FlowDirection=LeftToRight so HorizontalAlignment
            is literal — "Right" = the visual right edge unconditionally.
            Only visible in List mode (hidden during Editor).
        -->
        <!--
            The wrapping Grid stretches but has no Background → only the Button
            itself receives clicks; empty Grid area is non-hit-testable.
            We must NOT set IsHitTestVisible="False" on the Grid — that would
            propagate down and disable the FAB Button as well.
        -->
        <Grid FlowDirection="LeftToRight"
              Visibility="{Binding ShowList, Converter={StaticResource BoolToVisibility}}">
            <Button Style="{StaticResource FabButton}"
                    Command="{Binding AddStudentCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,28,28"
                    ToolTip="إضافة طالب (Ctrl+N)">
                <Path Data="{StaticResource IconAdd}"
                      Stroke="White"
                      StrokeThickness="2.6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"
                      Stretch="Uniform"
                      Width="24" Height="24" />
            </Button>
        </Grid>

        <controls:LoadingOverlay IsBusy="{Binding IsLoading}" Message="جاري تحميل قائمة الطلاب…" />
    </Grid>
</UserControl>
