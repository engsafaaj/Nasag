<UserControl x:Class="Nasag.Views.Pages.Students.StudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Nasag.Controls"
             xmlns:vm="clr-namespace:Nasag.ViewModels.Pages.Students"
             xmlns:helpers="clr-namespace:Nasag.Helpers"
             xmlns:views="clr-namespace:Nasag.Views.Pages.Students"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:StudentsViewModel}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <helpers:StudentStatusToArabicConverter x:Key="StatusToText" />
        <helpers:StudentStatusToBackgroundConverter x:Key="StatusBg" />
        <helpers:StudentStatusToForegroundConverter x:Key="StatusFg" />
        <helpers:StudentStatusEqualsConverter x:Key="StatusEquals" />
        <helpers:GenderToArabicConverter x:Key="GenderToText" />
        <helpers:InitialLetterConverter x:Key="InitialLetter" />
    </UserControl.Resources>

    <Grid>
        <!-- ==================== List Mode ==================== -->
        <Grid Visibility="{Binding ShowList, Converter={StaticResource BoolToVisibility}}"
              Margin="22,18,22,18">
            <Grid.RowDefinitions>
                <!-- Header (sticky top) -->
                <RowDefinition Height="Auto" />
                <!-- Toolbar (sticky top) -->
                <RowDefinition Height="Auto" />
                <!-- DataGrid card (fills remaining space, internal scroll) -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleAr}"
                               Style="{StaticResource SectionTitle}"
                               TextAlignment="Right"
                               HorizontalAlignment="Right" />
                    <TextBlock Style="{StaticResource SectionSubtitle}"
                               TextAlignment="Right"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0">
                        <Run Text="إجمالي: " />
                        <Run Text="{Binding AllCount, Mode=OneWay, StringFormat={}{0:N0}}"
                             FontWeight="Bold"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                        <Run Text=" • نشطون: " />
                        <Run Text="{Binding ActiveCount, Mode=OneWay, StringFormat={}{0:N0}}"
                             FontWeight="Bold"
                             Foreground="{StaticResource SuccessBrush}" />
                        <Run Text=" • مؤرشفون: " />
                        <Run Text="{Binding ArchivedCount, Mode=OneWay, StringFormat={}{0:N0}}"
                             FontWeight="Bold"
                             Foreground="{StaticResource WarningBrush}" />
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Toolbar: filters + add (sticky) -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Padding="14,10"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource BackgroundBrush}"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="10,2"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            MinWidth="280"
                            MaxWidth="380"
                            HorizontalAlignment="Right">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0"
                                  Data="{StaticResource IconSearch}"
                                  Stroke="{StaticResource TextMutedBrush}"
                                  StrokeThickness="1.6"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="16" Height="16"
                                  VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MinHeight="30"
                                     VerticalContentAlignment="Center"
                                     Margin="8,0,0,0"
                                     Tag="بحث بالاسم أو الرقم أو الجوال…" />
                        </Grid>
                    </Border>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Grades}"
                              SelectedItem="{Binding SelectedGrade}"
                              DisplayMemberPath="NameAr"
                              MinWidth="130"
                              Margin="10,0,0,0"
                              ToolTip="فلترة حسب الصف" />

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding AvailableSections}"
                              SelectedItem="{Binding SelectedSection}"
                              DisplayMemberPath="NameAr"
                              MinWidth="110"
                              Margin="8,0,0,0"
                              ToolTip="فلترة حسب الشعبة" />

                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              DisplayMemberPath="Label"
                              MinWidth="120"
                              Margin="8,0,0,0"
                              ToolTip="فلترة حسب الحالة" />

                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding PageSizeOptions}"
                              SelectedItem="{Binding PageSize}"
                              MinWidth="70"
                              Margin="8,0,0,0"
                              ToolTip="عدد الصفوف لكل صفحة" />

                    <Button Grid.Column="5"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding ClearFiltersCommand}"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            ToolTip="مسح الفلاتر">
                        <Path Data="{StaticResource IconRefresh}"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14" />
                    </Button>

                    <Button Grid.Column="6"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ReloadCommand}"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            ToolTip="تحديث">
                        <Path Data="{StaticResource IconRefresh}"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Width="14" Height="14" />
                    </Button>

                    <Button Grid.Column="7"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddStudentCommand}"
                            Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconAdd}"
                                  Stroke="White"
                                  StrokeThickness="1.8"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="إضافة طالب"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- DataGrid card (fills) -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Students}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              IsReadOnly="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الطالب"
                                                Binding="{Binding StudentNumber}"
                                                Width="120" />

                            <DataGridTemplateColumn Header="الاسم" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,4">
                                            <Border Width="32" Height="32"
                                                    CornerRadius="16"
                                                    Background="{StaticResource TealSoftBrush}">
                                                <TextBlock Text="{Binding FullName, Converter={StaticResource InitialLetter}}"
                                                           Foreground="{StaticResource TealPressedBrush}"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="{Binding FullName}"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="الصف"
                                                Binding="{Binding GradeName}"
                                                Width="140" />

                            <DataGridTextColumn Header="الشعبة"
                                                Binding="{Binding SectionName}"
                                                Width="100" />

                            <DataGridTemplateColumn Header="الحالة" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="999"
                                                Padding="10,3"
                                                Margin="6,4"
                                                HorizontalAlignment="Right"
                                                Background="{Binding Status, Converter={StaticResource StatusBg}}">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusFg}}"
                                                       FontSize="{StaticResource FontSizeSm}"
                                                       FontWeight="Medium" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="الجوال"
                                                Binding="{Binding Phone}"
                                                Width="140" />

                            <DataGridTextColumn Header="ولي الأمر"
                                                Binding="{Binding GuardianName}"
                                                Width="180" />

                            <DataGridTemplateColumn Header="إجراءات" Width="170" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,2">
                                            <Button Style="{StaticResource RowActionButton}"
                                                    ToolTip="تعديل"
                                                    Command="{Binding DataContext.EditStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconEdit}"
                                                      Stroke="{StaticResource TextSecondaryBrush}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                            <Button Style="{StaticResource RowActionButton}"
                                                    ToolTip="أرشفة"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding DataContext.ArchiveStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Data="{StaticResource IconBackup}"
                                                      Stroke="{StaticResource WarningBrush}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                            <Button ToolTip="استعادة"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding DataContext.RestoreStudentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource RowActionButton}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status, Converter={StaticResource StatusEquals}, ConverterParameter=Archived}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Path Data="{StaticResource IconRefresh}"
                                                      Stroke="{StaticResource SuccessBrush}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Stretch="Uniform" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="0"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,40">
                        <Border Background="{StaticResource TealSoftBrush}"
                                Width="64" Height="64"
                                CornerRadius="32"
                                HorizontalAlignment="Center">
                            <Path Data="{StaticResource IconStudents}"
                                  Stroke="{StaticResource TealPressedBrush}"
                                  StrokeThickness="1.7"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="28" Height="28" />
                        </Border>
                        <TextBlock Text="لا توجد نتائج مطابقة"
                                   Style="{StaticResource SubheadTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0" />
                        <TextBlock Text="جرّب تعديل الفلاتر أو إضافة طالب جديد"
                                   Style="{StaticResource CaptionTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Pagination footer (sticky) -->
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="14,10"
                            Background="{StaticResource CardSurfaceBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PaginationLabel}"
                                       Style="{StaticResource MutedTextStyle}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding PrevPageCommand}"
                                        Margin="0,0,8,0"
                                        Padding="14,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconChevronRight}"
                                              Stroke="{StaticResource TextPrimaryBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Width="12" Height="12"
                                              VerticalAlignment="Center" />
                                        <TextBlock Text="السابق"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Border Background="{StaticResource BackgroundBrush}"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="14,6"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0">
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource BodyTextStyle}">
                                        <Run Text="صفحة" />
                                        <Run Text=" " />
                                        <Run Text="{Binding Page, Mode=OneWay}"
                                             FontWeight="Bold"
                                             Foreground="{StaticResource TealPressedBrush}" />
                                        <Run Text=" من " />
                                        <Run Text="{Binding TotalPages, Mode=OneWay}"
                                             FontWeight="Bold" />
                                    </TextBlock>
                                </Border>
                                <Button Style="{StaticResource SecondaryButton}"
                                        Command="{Binding NextPageCommand}"
                                        Padding="14,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="التالي"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                        <Path Data="{StaticResource IconChevronLeft}"
                                              Stroke="{StaticResource TextPrimaryBrush}"
                                              StrokeThickness="1.6"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Width="12" Height="12"
                                              VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== Editor Mode ==================== -->
        <Grid Visibility="{Binding ShowEditor, Converter={StaticResource BoolToVisibility}}">
            <views:StudentEditorView DataContext="{Binding Editor}" />
        </Grid>

        <controls:LoadingOverlay IsBusy="{Binding IsLoading}" Message="جاري تحميل قائمة الطلاب…" />
    </Grid>
</UserControl>
