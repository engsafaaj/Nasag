<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shared soft drop-shadow effect -->
    <DropShadowEffect x:Key="CardShadow"
                      Color="#1B3A57"
                      BlurRadius="18"
                      ShadowDepth="0"
                      Opacity="0.08" />

    <!-- White rounded card -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <Style x:Key="CardBorderLg" TargetType="Border" BasedOn="{StaticResource CardBorder}">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
        <Setter Property="Padding" Value="28" />
    </Style>

    <!-- Section header (used above content groups) -->
    <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeXl}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="SectionSubtitle" TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

</ResourceDictionary>
