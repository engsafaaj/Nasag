<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Nasag.ViewModels.Pages"
    xmlns:vmAttendance="clr-namespace:Nasag.ViewModels.Pages.Attendance"
    xmlns:vmStudents="clr-namespace:Nasag.ViewModels.Pages.Students"
    xmlns:vmClasses="clr-namespace:Nasag.ViewModels.Pages.Classes"
    xmlns:vmSubjects="clr-namespace:Nasag.ViewModels.Pages.Subjects"
    xmlns:vmExams="clr-namespace:Nasag.ViewModels.Pages.Exams"
    xmlns:vmMarks="clr-namespace:Nasag.ViewModels.Pages.Marks"
    xmlns:vmResults="clr-namespace:Nasag.ViewModels.Pages.Results"
    xmlns:vmFees="clr-namespace:Nasag.ViewModels.Pages.Fees"
    xmlns:reportsVm="clr-namespace:Nasag.ViewModels.Pages.Reports"
    xmlns:reportsViews="clr-namespace:Nasag.Views.Pages.Reports"
    xmlns:vmSettings="clr-namespace:Nasag.ViewModels.Pages.Settings"
    xmlns:viewsSettings="clr-namespace:Nasag.Views.Pages.Settings"
    xmlns:vmUsers="clr-namespace:Nasag.ViewModels.Pages.Users"
    xmlns:viewsUsers="clr-namespace:Nasag.Views.Pages.Users"
    xmlns:vmBackup="clr-namespace:Nasag.ViewModels.Pages.Backup"
    xmlns:viewsBackup="clr-namespace:Nasag.Views.Pages.Backup"
    xmlns:views="clr-namespace:Nasag.Views.Pages"
    xmlns:viewsAttendance="clr-namespace:Nasag.Views.Pages.Attendance"
    xmlns:viewsStudents="clr-namespace:Nasag.Views.Pages.Students"
    xmlns:viewsClasses="clr-namespace:Nasag.Views.Pages.Classes"
    xmlns:viewsSubjects="clr-namespace:Nasag.Views.Pages.Subjects"
    xmlns:viewsExams="clr-namespace:Nasag.Views.Pages.Exams"
    xmlns:viewsMarks="clr-namespace:Nasag.Views.Pages.Marks"
    xmlns:viewsResults="clr-namespace:Nasag.Views.Pages.Results"
    xmlns:viewsFees="clr-namespace:Nasag.Views.Pages.Fees">

    <!--
        Each PageViewModel is mapped to a View through an implicit DataTemplate.
        Until per-page views are built, all pages use PagePlaceholderView.
        To activate a real view: replace the corresponding DataTemplate's content.
    -->

    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
        <views:DashboardView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmStudents:StudentsViewModel}">
        <viewsStudents:StudentsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmClasses:ClassesViewModel}">
        <viewsClasses:ClassesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmAttendance:AttendanceViewModel}">
        <viewsAttendance:AttendanceView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSubjects:SubjectsViewModel}">
        <viewsSubjects:SubjectsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmExams:ExamsViewModel}">
        <viewsExams:ExamsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmMarks:MarksViewModel}">
        <viewsMarks:MarksView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmResults:ResultsViewModel}">
        <viewsResults:ResultsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmFees:FeesViewModel}">
        <viewsFees:FeesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type reportsVm:ReportsViewModel}">
        <reportsViews:ReportsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmUsers:UsersViewModel}">
        <viewsUsers:UsersView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmSettings:SettingsViewModel}">
        <viewsSettings:SettingsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vmBackup:BackupViewModel}">
        <viewsBackup:BackupView />
    </DataTemplate>

</ResourceDictionary>
