<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Nasag.Helpers">

    <helpers:ComboBoxDisplayTextConverter x:Key="ComboBoxDisplayText" />

    <!-- Shared input template root -->
    <ControlTemplate x:Key="RoundedInputTemplate" TargetType="TextBoxBase">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{StaticResource RadiusSm}"
                SnapsToDevicePixels="True">
            <ScrollViewer x:Name="PART_ContentHost"
                          Focusable="False"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="{TemplateBinding Padding}" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Root" Property="Opacity" Value="0.6" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource TealPrimaryBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource TajawalFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CaretBrush" Value="{StaticResource TealPrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource TealSoftBrush}" />
        <Setter Property="Template" Value="{StaticResource RoundedInputTemplate}" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{StaticResource TajawalFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CaretBrush" Value="{StaticResource TealPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      Padding="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource TealPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem inside the dropdown popup -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="FontFamily" Value="{StaticResource TajawalFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Root"
                            Background="Transparent"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TealSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource TealSoftBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TealPressedBrush}" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Toggle button used as the ComboBox face. Modeled after the default WPF
        Aero ComboBoxReadonlyToggleButton: a chromeless Button that spans the
        whole control. ClickMode=Release toggles IsDropDownOpen after the click so
        the popup opens reliably with a single click; the content layer that
        actually renders the selected item lives ABOVE this button with
        IsHitTestVisible=False, so clicks always reach the toggle.
    -->
    <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ClickMode" Value="Release" />
        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="FieldRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusSm}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Chevron sits on the visual-left under RTL (column 0) -->
                            <Border Grid.Column="0"
                                    Width="28"
                                    Background="Transparent">
                                <Path Data="M6 9 L12 15 L18 9"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.6"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Width="12" Height="12"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="FieldRoot" Property="BorderBrush" Value="{StaticResource TealPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="FieldRoot" Property="BorderBrush" Value="{StaticResource TealPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Themed ComboBox — rounded card face, teal accent on focus, custom chevron.

        Layout (default WPF Aero pattern):
            • ToggleButton spans the WHOLE control and handles all clicks.
            • A separate text layer sits ON TOP with IsHitTestVisible=False
              so the selected item renders correctly without intercepting clicks.
            • Popup is opened/closed via TwoWay IsChecked ↔ IsDropDownOpen.

        Single-click open works because the text layer does not capture the
        click — it falls through to the toggle button below.
    -->
    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource TajawalFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="34,6,12,6" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <!-- Toggle covers the entire face so any click on the field opens the popup. -->
                        <ToggleButton x:Name="PART_ToggleButton"
                                      Style="{StaticResource ComboBoxToggleButton}"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />

                        <!--
                            Text overlay. IsHitTestVisible=False is the
                            key — without it, clicks would land on the presenter and
                            never reach the ToggleButton, so the popup would not open.
                            FlowDirection=RightToLeft + HorizontalAlignment=Right
                            keep the selected text and placeholder anchored to the
                            visual right under RTL.
                        -->
                        <TextBlock x:Name="ContentSite"
                                   Margin="{TemplateBinding Padding}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FlowDirection="RightToLeft"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   IsHitTestVisible="False"
                                   SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource ComboBoxDisplayText}">
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="SelectionBoxItem" />
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="DisplayMemberPath" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- Placeholder shown only when there is no selection -->
                        <TextBlock x:Name="Placeholder"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="{StaticResource TajawalFont}"
                                   FontSize="{StaticResource FontSizeBase}"
                                   Margin="{TemplateBinding Padding}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FlowDirection="RightToLeft"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed" />

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               PopupAnimation="Fade"
                               Focusable="False">
                            <Border MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource CardSurfaceBrush}"
                                    BorderBrush="{StaticResource BorderStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusSm}"
                                    Margin="0,4,0,0"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#1B3A57" BlurRadius="18" ShadowDepth="0" Opacity="0.18" />
                                </Border.Effect>
                                <ScrollViewer SnapsToDevicePixels="True"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Show placeholder when nothing selected (SelectedItem is null AND Text is empty) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="HasItems" Value="True" />
                                <Condition Property="SelectedIndex" Value="-1" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="SelectedIndex" Value="-1">
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="FontFamily" Value="{StaticResource TajawalFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- Field label (small caption above input) -->
    <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

</ResourceDictionary>
