<Application x:Class="Nasag.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Nasag">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Typography.xaml" />
                <ResourceDictionary Source="Themes/Common.xaml" />
                <ResourceDictionary Source="Themes/Icons.xaml" />
                <ResourceDictionary Source="Themes/Buttons.xaml" />
                <ResourceDictionary Source="Themes/Inputs.xaml" />
                <ResourceDictionary Source="Themes/Cards.xaml" />
                <ResourceDictionary Source="Themes/StatusPills.xaml" />
                <ResourceDictionary Source="Themes/DataGrid.xaml" />
                <ResourceDictionary Source="Themes/DataTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
