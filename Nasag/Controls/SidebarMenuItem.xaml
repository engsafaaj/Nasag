<UserControl x:Class="Nasag.Controls.SidebarMenuItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             x:Name="Root"
             Cursor="Hand"
             FlowDirection="LeftToRight">
    <UserControl.Resources>
        <Style x:Key="ItemRoot" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusSm}" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="10,2" />
        </Style>
    </UserControl.Resources>
    <Border x:Name="ItemBorder" Style="{StaticResource ItemRoot}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Path Grid.Column="2"
                  x:Name="IconPath"
                  Data="{Binding IconGeometry, ElementName=Root}"
                  Stroke="{Binding ContentBrush, ElementName=Root}"
                  StrokeThickness="1.6"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  Fill="Transparent"
                  Stretch="Uniform"
                  Width="20" Height="20"
                  VerticalAlignment="Center" />

            <TextBlock Grid.Column="1"
                       x:Name="LabelText"
                       Text="{Binding Label, ElementName=Root}"
                       Foreground="{Binding ContentBrush, ElementName=Root}"
                       FontFamily="{StaticResource TajawalFont}"
                       FontSize="{StaticResource FontSizeBase}"
                       FontWeight="Medium"
                       FlowDirection="RightToLeft"
                       TextAlignment="Left"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center" />

            <Border Grid.Column="0"
                    x:Name="ActiveStrip"
                    Background="{StaticResource TealPrimaryBrush}"
                    Width="3" CornerRadius="2"
                    HorizontalAlignment="Left"
                    Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>
