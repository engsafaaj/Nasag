<UserControl x:Class="Nasag.Controls.SearchableComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             FocusVisualStyle="{x:Null}">

    <UserControl.Resources>
        <Style x:Key="ComboPopupItem" TargetType="ListBoxItem">
            <Setter Property="FontFamily" Value="{StaticResource TajawalFont}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource TealSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource TealSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TealPressedBrush}" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" MinHeight="36">
        <!-- Field face -->
        <Border x:Name="FieldRoot"
                Background="{StaticResource CardSurfaceBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}"
                MinHeight="36"
                Cursor="IBeam">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="QueryBox"
                         Grid.Column="2"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="10,6,12,6"
                         MinHeight="32"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Right"
                         TextAlignment="Right"
                         FlowDirection="RightToLeft"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         CaretBrush="{StaticResource TealPrimaryBrush}"
                         TextChanged="OnQueryTextChanged"
                         GotKeyboardFocus="OnQueryGotFocus"
                         PreviewKeyDown="OnQueryKeyDown" />

                <Button x:Name="ClearButton"
                        Grid.Column="1"
                        Style="{StaticResource IconButton}"
                        Width="24" Height="24"
                        Padding="0"
                        Margin="0,0,4,0"
                        Click="OnClearClick"
                        ToolTip="مسح"
                        Visibility="Collapsed">
                    <Path Data="M6 6 L18 18 M18 6 L6 18"
                          Stroke="{StaticResource TextMutedBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="10" Height="10" />
                </Button>

                <Border Grid.Column="0"
                        Width="28"
                        Background="Transparent"
                        Cursor="Hand"
                        MouseLeftButtonDown="OnDropDownToggle">
                    <Path Data="M6 9 L12 15 L18 9"
                          Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.6"
                          Fill="Transparent"
                          Stretch="Uniform"
                          Width="12" Height="12"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Placeholder hint -->
        <TextBlock x:Name="PlaceholderText"
                   IsHitTestVisible="False"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontFamily="{StaticResource TajawalFont}"
                   FontSize="{StaticResource FontSizeBase}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   FlowDirection="RightToLeft"
                   TextAlignment="Right"
                   Margin="36,0,12,0"
                   Text="اختر..." />

        <Popup x:Name="DropdownPopup"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=FieldRoot}"
               Width="{Binding ElementName=FieldRoot, Path=ActualWidth}"
               Closed="OnDropdownClosed">
            <Border Background="{StaticResource CardSurfaceBrush}"
                    BorderBrush="{StaticResource BorderStrongBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}"
                    Margin="0,4,0,0"
                    MaxHeight="280"
                    FlowDirection="RightToLeft">
                <Border.Effect>
                    <DropShadowEffect Color="#1B3A57" BlurRadius="18" ShadowDepth="0" Opacity="0.18" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="SuggestionList"
                             Grid.Row="0"
                             Focusable="False"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ItemContainerStyle="{StaticResource ComboPopupItem}"
                             MouseLeftButtonUp="OnSuggestionClicked"
                             KeyDown="OnSuggestionKeyDown" />

                    <Border Grid.Row="0"
                            x:Name="EmptyPanel"
                            Padding="14,18"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="لا توجد نتائج"
                                       Style="{StaticResource MutedTextStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="جرّب مصطلحاً آخر"
                                       Style="{StaticResource CaptionTextStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
