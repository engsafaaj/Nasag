<UserControl x:Class="Nasag.Controls.ToastHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svc="clr-namespace:Nasag.Services"
             mc:Ignorable="d"
             IsHitTestVisible="True"
             Background="Transparent"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style x:Key="ToastBorderBase" TargetType="Border">
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="MinWidth" Value="320" />
            <Setter Property="MaxWidth" Value="420" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1B3A57"
                                      BlurRadius="22"
                                      ShadowDepth="0"
                                      Opacity="0.18" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,20,0">
        <ItemsControl x:Name="ToastList">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type svc:ToastItem}">
                    <Border Style="{StaticResource ToastBorderBase}">
                        <Border.Background>
                            <SolidColorBrush x:Name="BgBrush" Color="#FFFFFF" />
                        </Border.Background>
                        <Border.Resources>
                            <Style TargetType="Border" BasedOn="{StaticResource ToastBorderBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="Success">
                                        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,4,0" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Kind}" Value="Error">
                                        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,4,0" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,4,0" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Kind}" Value="Info">
                                        <Setter Property="Background" Value="{StaticResource CardSurfaceBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,4,0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="32" Height="32"
                                    CornerRadius="16"
                                    VerticalAlignment="Top">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="Success">
                                                <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Info">
                                                <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Path StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Width="18" Height="18">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Kind}" Value="Success">
                                                    <Setter Property="Data" Value="M5 12 L10 17 L20 7" />
                                                    <Setter Property="Stroke" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                    <Setter Property="Data" Value="M6 6 L18 18 M18 6 L6 18" />
                                                    <Setter Property="Stroke" Value="{StaticResource DangerBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                                    <Setter Property="Data" Value="M12 8 V13 M12 17 H12.01 M2 20 L12 4 L22 20 Z" />
                                                    <Setter Property="Stroke" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Kind}" Value="Info">
                                                    <Setter Property="Data" Value="M12 8 H12.01 M11 12 H12 V17 H13" />
                                                    <Setter Property="Stroke" Value="{StaticResource InfoBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="Bold"
                                           Style="{StaticResource BodyTextStyle}" />
                                <TextBlock Text="{Binding Message}"
                                           FontSize="{StaticResource FontSizeSm}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Message}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Message}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Style="{StaticResource IconButton}"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Tag="{Binding Id}"
                                    Click="OnDismissClick"
                                    VerticalAlignment="Top">
                                <Path Data="M6 6 L18 18 M18 6 L6 18"
                                      Stroke="{StaticResource TextMutedBrush}"
                                      StrokeThickness="1.6"
                                      Fill="Transparent"
                                      Stretch="Uniform"
                                      Width="12" Height="12" />
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
